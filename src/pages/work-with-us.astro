<BaseLayout title="Work With Us">
    <main
        class="max-w-screen-2xl w-full mx-auto text-lewrap-off-black flex flex-col gap-5"
    >
        {/* Hero section */}
        <HeroSection
            title="Work With Us!"
            image={heroImage}
            ctaText="Apply now"
            ctaHref="/"
        />
        {/* // Hero section */}

        {/* Marquee */}
        <Marquee
            className="w-[95%] mx-auto bg-lewrap-green py-4 rounded-2xl"
            separator={leWrapSeparator}
            items={[
                '<span class="text-white text-xl font-helvetica-condensed">Chicken Wraps</span>',
                '<span class="text-white text-xl font-helvetica-condensed">Schnitzel Wraps</span>',
                '<span class="text-white text-xl font-helvetica-condensed">Beef Wraps</span>',
                '<span class="text-white text-xl font-helvetica-condensed">Lamb Wraps</span>',
                '<span class="text-white text-xl font-helvetica-condensed">Vegetarian Wraps</span>',
                '<span class="text-white text-xl font-helvetica-condensed">Plates</span>',
                '<span class="text-white text-xl font-helvetica-condensed">Baguettes</span>',
                '<span class="text-white text-xl font-helvetica-condensed">Salads</span>',
                '<span class="text-white text-xl font-helvetica-condensed">Kids Meals</span>',
                '<span class="text-white text-xl font-helvetica-condensed">Sides</span>',
                '<span class="text-white text-xl font-helvetica-condensed">Drinks</span>',
            ]}
        />
        {/* // Marquee */}
    </main>
</BaseLayout>
