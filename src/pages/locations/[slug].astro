---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

import Button from "../../components/atoms/Button.astro";

export async function getStaticPaths() {
    const locations = await getCollection("locations");
    return locations.map((location) => ({
        params: { slug: location.slug },
        props: { location },
    }));
}

interface Props {
    location: CollectionEntry<"locations">;
}

const { location } = Astro.props;
const { Content } = await location.render();

// Format hours for display
const daysOfWeek = [
    "monday",
    "tuesday",
    "wednesday",
    "thursday",
    "friday",
    "saturday",
    "sunday",
];
const dayLabels: Record<string, string> = {
    monday: "Monday",
    tuesday: "Tuesday",
    wednesday: "Wednesday",
    thursday: "Thursday",
    friday: "Friday",
    saturday: "Saturday",
    sunday: "Sunday",
};
---

<BaseLayout title={`${location.data.name} | LeWrap Locations`}>
    <main
        class="max-w-screen-2xl w-full mx-auto text-lewrap-off-black flex flex-col gap-10"
    >
        <div class="relative">
            <section
                class="grid grid-cols-1 md:grid-cols-2 items-center justify-center mt-10 md:mt-15 w-[95%] mx-auto min-h-[62vh] md:h-[75vh] rounded-2xl overflow-hidden bg-white"
            >
                {
                    /* Google Map NOTE: THIS MIGHT BREAK WITH LOCATIONS THAT AREN'T INDEXED YET. CHECK BEST WAY TO SOLVE THIS */
                }
                <iframe
                    width="100%"
                    height="100%"
                    style="border:0"
                    loading="lazy"
                    class="min-h-[40vh]"
                    allowfullscreen
                    referrerpolicy="no-referrer-when-downgrade"
                    src={`https://maps.google.com/maps?q=${encodeURIComponent(location.data.name)}&tbm=map&output=embed`}
                ></iframe>

                {/* Location details */}
                <div
                    class="flex flex-col p-8 py-10 items-center justify-center gap-y-6"
                >
                    <div class="flex flex-col items-center">
                        <a
                            href="/locations"
                            class="text-lewrap-green hover:text-lewrap-green-dark font-semibold transition-colors"
                        >
                            View all locations
                        </a>

                        {/* Location name */}
                        <h1
                            class="text-5xl md:text-6xl font-black text-lewrap-green-dark text-center"
                        >
                            {location.data.name}
                        </h1>
                    </div>

                    <div class="flex flex-col text-lg">
                        {/* Address */}
                        <p class="text-center">
                            {location.data.address}, {location.data.suburb}, {
                                location.data.state
                            }
                            {location.data.postcode}
                        </p>

                        {/* Phone, email */}
                        {
                            location.data.phone && (
                                <a
                                    href={`tel:${location.data.phone}`}
                                    class="hover:text-lewrap-green text-center duration-200"
                                >
                                    {location.data.phone}
                                </a>
                            )
                        }
                        {
                            location.data.email && (
                                <a
                                    href={`mailto:${location.data.email}?subject=Enquiry%20from%20website`}
                                    class="hover:text-lewrap-green text-center duration-200"
                                >
                                    {location.data.email}
                                </a>
                            )
                        }
                    </div>

                    {/* View larger map */}
                    <Button
                        href={`https://www.google.com/maps/dir/?api=1&destination=${location.data.latitude},${location.data.longitude}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="px-5 py-3 text-sm"
                    >
                        Get Directions
                    </Button>

                    {/* Hours */}
                    <div class="w-[90%] md:w-[50%]">
                        <h2
                            class="text-3xl font-black text-lewrap-green-dark text-center mb-4"
                        >
                            Hours
                        </h2>
                        <div class="space-y-1">
                            {
                                daysOfWeek.map((day) => (
                                    <div class="flex justify-between items-center text-lg">
                                        <span class="capitalize">
                                            {dayLabels[day]}
                                        </span>
                                        <span
                                            class={`font-bold ${
                                                location.data.hours[
                                                    day as keyof typeof location.data.hours
                                                ] === "Closed"
                                                    ? "text-red-600"
                                                    : ""
                                            }`}
                                        >
                                            {
                                                location.data.hours[
                                                    day as keyof typeof location.data.hours
                                                ]
                                            }
                                        </span>
                                    </div>
                                ))
                            }
                        </div>
                    </div>
                </div>

                {/* Arrow */}
                <img
                    src="/images/elements/arrow-green-fat.svg"
                    alt="More about LeWrap"
                    class="w-10 h-auto absolute left-1/2 md:left-3/4 -translate-x-1/2 -bottom-14"
                />
            </section>
        </div>

        {/* Location paragraph, image */}
        <section
            class="w-[95%] mx-auto bg-cover bg-center bg-no-repeat p-7 rounded-2xl grid md:grid-cols-2 relative"
        >
            <div class="max-w-xl mx-auto flex flex-col gap-y-8 py-16">
                <h2 class="text-5xl font-black text-lewrap-green-dark">
                    {location.data.name}
                </h2>

                <div
                    class="prose text-2xl/8 text-lewrap-off-black [&_p]:mb-8 [&_p:last-child]:mb-0"
                >
                    <Content />
                </div>
            </div>

            {/* Store Image */}
            {
                location.data.image && (
                    <div class="rounded-xl overflow-hidden">
                        <img
                            src={location.data.image}
                            alt={location.data.name}
                            class="w-full h-full object-cover"
                        />
                    </div>
                )
            }
        </section>

        {/* Find us, contact, hours */}
        <section
            class="w-[95%] md:w-auto max-w-screen-xl mx-auto bg-cover bg-center bg-no-repeat rounded-2xl overflow-hidden grid md:grid-cols-2"
            style="background-image: url('/images/bg-tile-wood.webp'); background-repeat: repeat;"
        >
            <div
                class="mx-auto flex flex-col p-7 py-16 bg-lewrap-green text-lg/6 text-lewrap-off-black"
            >
                <h2 class="text-4xl font-black text-white mb-8">Find us</h2>
                {/* Address */}
                <p class="w-[80%] mb-4">
                    {location.data.address}, {location.data.suburb}, {
                        location.data.state
                    }
                    {location.data.postcode}
                </p>
                {/* View larger map */}
                <Button
                    href={`https://www.google.com/maps/dir/?api=1&destination=${location.data.latitude},${location.data.longitude}`}
                    target="_blank"
                    variant="secondary"
                    rel="noopener noreferrer"
                    class="px-5 py-3 text-sm border-none hover:bg-lewrap-green-dark hover:text-lewrap-green"
                >
                    Get Directions
                </Button>

                <h2 class="text-4xl font-black text-white mt-10 mb-8">
                    Contact
                </h2>
                {/* Phone, email */}
                {
                    location.data.phone && (
                        <a
                            href={`tel:${location.data.phone}`}
                            class="text-lewrap-green-dark hover:text-white duration-200"
                        >
                            {location.data.phone}
                        </a>
                    )
                }
                {
                    location.data.email && (
                        <a
                            href={`mailto:${location.data.email}?subject=Enquiry%20from%20website`}
                            class="text-lewrap-green-dark hover:text-white duration-200"
                        >
                            {location.data.email}
                        </a>
                    )
                }
            </div>

            <div
                class="w-full mx-auto flex flex-col gap-y-8 p-7 py-16 text-2xl/8 text-lewrap-off-black"
            >
                <h2 class="text-4xl font-black text-lewrap-green-dark">
                    Hours
                </h2>

                {/* Hours */}
                <div>
                    <div class="space-y-1">
                        {
                            daysOfWeek.map((day) => (
                                <div class="flex justify-between items-center text-lg">
                                    <span class="capitalize">
                                        {dayLabels[day]}
                                    </span>
                                    <span
                                        class={`font-bold ${
                                            location.data.hours[
                                                day as keyof typeof location.data.hours
                                            ] === "Closed"
                                                ? "text-red-600"
                                                : ""
                                        }`}
                                    >
                                        {
                                            location.data.hours[
                                                day as keyof typeof location.data.hours
                                            ]
                                        }
                                    </span>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>
