---
import Layout from "../layouts/Layout.astro";
import Carousel from "../components/molecules/Carousel";
import ScrollReveal from "../components/molecules/ScrollReveal";
import LeftScrollReveal from "../components/molecules/LeftScrollReveal";

const heroSlides = [
    {
        type: "image",
        src: "/home/home-slider-01.webp",
        alt: "Food image 1",
        objectFit: "cover",
    },
    {
        type: "image",
        src: "/home/home-slider-01.webp",
        alt: "Food image 2",
        objectFit: "cover",
    },
    {
        type: "image",
        src: "/home/home-slider-01.webp",
        alt: "Food image 3",
        objectFit: "cover",
    },
];
---

<Layout title="LeWrap - Home">
    <main class="text-lewrap-off-black">
        <div class="max-w-screen-2xl w-full mx-auto flex flex-col gap-16">
            {/* Hero slider */}
            <section class="mt-10 md:mt-15">
                <Carousel
                    client:load
                    slides={heroSlides}
                    showPagination={true}
                    showNavigation={true}
                    autoplay={{
                        delay: 5000,
                        disableOnInteraction: false,
                    }}
                    cta={{
                        text: "Our food",
                        href: "/our-food",
                    }}
                    cta2={{
                        text: "Order now",
                        href: "/order",
                        className: "text-lewrap-green",
                    }}
                    loop={true}
                    hasGradient={true}
                    className="w-[95%] mx-auto h-[62vh] md:h-[75vh] rounded-2xl overflow-hidden"
                />
            </section>

            <div
                class="flex flex-col items-center gap-4 px-4 text-center max-w-4xl mx-auto"
            >
                <h1 class="text-4xl font-bold">Home Page</h1>
                <p class="text-xl">
                    Check out these cool page transitions. Website on another
                    level.
                </p>
                <p class="text-xl">
                    Plus our customised cursor for added bougieness.
                </p>
            </div>

            <div class="flex flex-col md:flex-row gap-10 justify-center pb-20">
                <ScrollReveal client:load delay={0}>
                    <a
                        href="/locations"
                        class="px-6 py-3 bg-blue-500 text-white rounded-full font-semibold hover:bg-opacity-90 transition block"
                    >
                        Go to Locations
                    </a>
                </ScrollReveal>
                <ScrollReveal client:load delay={0.2}>
                    <a
                        href="/our-food"
                        class="px-6 py-3 bg-purple-600 text-white rounded-full font-semibold hover:bg-opacity-90 transition block"
                    >
                        Go to Our Food
                    </a>
                </ScrollReveal>
                <ScrollReveal client:load delay={0.4}>
                    <a
                        href="/nutrition"
                        class="px-6 py-3 bg-emerald-600 text-white rounded-full font-semibold hover:bg-opacity-90 transition block"
                    >
                        Go to Nutrition
                    </a>
                </ScrollReveal>
            </div>

            <div
                class="h-[150vh] w-full flex items-center justify-center mt-20 bg-gray-50"
            >
                <LeftScrollReveal client:load>
                    <p class="text-gray-500">
                        Keep scrolling to see the nav shrink...
                    </p>
                </LeftScrollReveal>
            </div>
        </div>
    </main>
</Layout>
