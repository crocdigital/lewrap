---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Our Food">
    <main class="bg-purple-600 text-white">
        <div
            class="min-h-screen flex flex-col items-center justify-center gap-8"
        >
            <h1 class="text-4xl font-bold">Our Food</h1>
            <p class="text-xl">This is the Our Food dummy page.</p>
            <div class="flex gap-4">
                <a
                    href="/"
                    class="px-6 py-3 bg-white text-purple-600 rounded-full font-semibold hover:bg-opacity-90 transition"
                >
                    Go Home
                </a>
                <a
                    href="/nutrition"
                    class="px-6 py-3 bg-purple-800 text-white rounded-full font-semibold hover:bg-opacity-90 transition"
                >
                    Go to Nutrition
                </a>
            </div>
        </div>
        <div class="h-[150vh] w-full flex items-center justify-center mt-20">
            <p class="text-purple-200">
                Keep scrolling to see the nav shrink...
            </p>
        </div>
    </main>
</Layout>
