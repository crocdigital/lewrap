---
import Layout from "../layouts/Layout.astro";
import MarqueeExample from "../components/examples/MarqueeExample.astro";
---

<Layout title="Component Examples">
    <main class="text-lewrap-off-black">
        <div class="max-w-screen-2xl w-full mx-auto flex flex-col gap-16 py-20">
            <div class="text-center px-4">
                <h1 class="text-4xl font-bold font-cocogoose mb-4">
                    Component Examples
                </h1>
                <p class="text-xl text-gray-600">
                    Preview of reusable components
                </p>
            </div>

            <section>
                <h2 class="text-3xl font-bold font-cocogoose mb-8 px-4">
                    Marquee Component
                </h2>
                <MarqueeExample />
            </section>
        </div>
    </main>
</Layout>
