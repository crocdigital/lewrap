---
interface Props {
    question: string;
    answer: string;
    index: number;
}

const { question, answer, index } = Astro.props;
const id = `faq-${index}`;
---

<div class="border-b border-lewrap-green">
    <button
        class="w-full text-left py-6 flex justify-between items-center gap-4 hover:text-lewrap-green transition-colors"
        data-faq-trigger={id}
        aria-expanded="false"
        aria-controls={id}
    >
        <h3 class="text-xl font-bold text-lewrap-green-dark pr-4">
            {question}
        </h3>
        <svg
            class="w-10 h-10 flex-shrink-0 transition-transform duration-300"
            data-faq-icon={id}
            viewBox="0 0 38 38"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
        >
            <circle
                cx="19"
                cy="19"
                r="18"
                fill="white"
                stroke="#95BA32"
                stroke-width="2"></circle>
            <path
                d="M26.8297 16.0112L18.9126 23.8303C18.8743 23.8634 18.8317 23.8914 18.7861 23.9133C18.7656 23.929 18.7441 23.9432 18.7217 23.9561C18.5798 24.0146 18.4206 24.0146 18.2787 23.9561C18.2563 23.9432 18.2348 23.929 18.2143 23.9133C18.1687 23.8914 18.1261 23.8634 18.0878 23.8303L10.1707 16.0112C10.0618 15.9005 10.0004 15.751 10 15.5951C9.99958 15.4391 10.0601 15.2893 10.1685 15.178C10.2768 15.0666 10.4243 15.0027 10.5791 15.0001C10.7339 14.9974 10.8835 15.0562 10.9956 15.1638L18.5002 22.5754L26.0044 15.1638C26.1165 15.0562 26.2661 14.9974 26.4209 15.0001C26.5757 15.0027 26.7232 15.0666 26.8315 15.178C26.9399 15.2893 27.0004 15.4391 27 15.5951C26.9996 15.751 26.9386 15.9005 26.8297 16.0112Z"
                fill="#95BA32"></path>
        </svg>
    </button>

    <div
        id={id}
        class="overflow-hidden transition-all duration-300 ease-in-out"
        style="max-height: 0;"
        data-faq-content={id}
    >
        <div
            class="pb-6 prose text-lg text-lewrap-off-black [&_p]:mb-2 [&_ul]:list-disc [&_ul]:pl-10"
            set:html={answer}
        />
    </div>
</div>

<script>
    document.addEventListener("astro:page-load", () => {
        const triggers = document.querySelectorAll("[data-faq-trigger]");

        triggers.forEach((trigger) => {
            trigger.addEventListener("click", () => {
                const id = trigger.getAttribute("data-faq-trigger");
                const content = document.querySelector(
                    `[data-faq-content="${id}"]`,
                ) as HTMLElement;
                const icon = document.querySelector(
                    `[data-faq-icon="${id}"]`,
                ) as HTMLElement;
                const isOpen = trigger.getAttribute("aria-expanded") === "true";

                if (isOpen) {
                    // Close
                    content.style.maxHeight = "0";
                    trigger.setAttribute("aria-expanded", "false");
                    icon.style.transform = "rotate(0deg)";
                } else {
                    // Open
                    content.style.maxHeight = content.scrollHeight + "px";
                    trigger.setAttribute("aria-expanded", "true");
                    icon.style.transform = "rotate(180deg)";
                }
            });
        });
    });
</script>
