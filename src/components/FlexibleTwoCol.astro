---
import Button from "./atoms/Button.astro";
import Carousel from "./molecules/Carousel";

interface Slide {
    image: string;
    alt: string;
}

interface Props {
    title: string;
    description: string;
    buttonText?: string;
    buttonLink?: string;
    buttonVariant?: "primary" | "secondary";
    bgColor?: string;
    reverse?: boolean;
    index?: number;
    slides?: Slide[];
}

const {
    title,
    description,
    buttonText,
    buttonLink,
    buttonVariant = "primary",
    bgColor = "#95BA32",
    reverse = false,
    index = 0,
    slides = [],
} = Astro.props;

// Transform slides for Carousel component
const carouselSlides = slides.map((slide) => ({
    type: "image" as const,
    src: slide.image,
    alt: slide.alt,
    objectFit: "contain" as const,
}));

const hasSlides = slides.length > 0;
---

<div
    class={`grid grid-cols-1 md:grid-cols-[2fr_1fr] gap-8 ${reverse ? "md:grid-cols-[1fr_2fr]" : ""}`}
>
    {/* Left column - carousel or colored background */}
    <div class={`rounded-xl overflow-hidden ${reverse ? "md:order-2" : ""}`}>
        {
            hasSlides ? (
                <Carousel
                    client:load
                    slides={carouselSlides}
                    showPagination={true}
                    showNavigation={true}
                    autoplay={{
                        delay: 5000,
                        disableOnInteraction: false,
                    }}
                    loop={true}
                    height=""
                    className="w-full aspect-[3/2]"
                />
            ) : (
                <div
                    class="min-h-[400px] flex items-center justify-center"
                    style={`background-color: ${bgColor};`}
                >
                    <p class="text-white text-2xl font-bold">
                        Add slides to show carousel
                    </p>
                </div>
            )
        }
    </div>

    {/* Right column */}
    <div
        class={`flex flex-col justify-center gap-6 p-7 md:p-0 ${reverse ? "md:order-1" : ""}`}
    >
        <h2
            class="text-lewrap-green-dark text-5xl/11 md:text-6xl/14 font-black tracking-tight"
            data-prop={`flexible_two_col.${index}.title`}
            data-cms-bind={`#flexible_two_col.${index}.title`}
        >
            {title}
        </h2>

        <div
            class="prose text-2xl/8 text-lewrap-off-black [&_p]:mb-8 [&_p:last-child]:mb-0"
            data-cms-bind={`#flexible_two_col.${index}.description`}
            set:html={description}
        />

        {
            buttonText && buttonLink && (
                <Button href={buttonLink} variant={buttonVariant}>
                    {buttonText}
                </Button>
            )
        }
    </div>
</div>
