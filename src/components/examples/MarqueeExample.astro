---
import Marquee from "../molecules/Marquee.astro";

// Custom SVG separator (star icon example)
const starSeparator = `
  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
  </svg>
`;
---

<div class="py-20 space-y-10">
    <!-- Example 1: Default marquee -->
    <Marquee
        className="bg-lewrap-green py-6"
        items={[
            '<span class="text-white text-2xl font-cocogoose">Fresh Ingredients</span>',
            '<span class="text-white text-2xl font-cocogoose">Healthy Wraps</span>',
            '<span class="text-white text-2xl font-cocogoose">Made Daily</span>',
            '<span class="text-white text-2xl font-cocogoose">100% Natural</span>',
        ]}
    />

    <!-- Example 2: Custom speed and separator -->
    <Marquee
        speed={15}
        separator={starSeparator}
        className="bg-lewrap-green-dark py-6"
        gradientColor="#31411D"
        gradientWidth={150}
        items={[
            '<span class="text-lewrap-green text-3xl font-bold">FAST</span>',
            '<span class="text-lewrap-green text-3xl font-bold">FRESH</span>',
            '<span class="text-lewrap-green text-3xl font-bold">DELICIOUS</span>',
        ]}
    />

    <!-- Example 3: Slow marquee with custom gradient -->
    <Marquee
        speed={30}
        separator={starSeparator}
        className="bg-white py-8"
        gradientColor="white"
        gradientWidth={120}
        items={[
            '<span class="text-lewrap-off-black text-xl font-helvetica-condensed font-bold uppercase">Order Online</span>',
            '<span class="text-lewrap-off-black text-xl font-helvetica-condensed font-bold uppercase">Dine In</span>',
            '<span class="text-lewrap-off-black text-xl font-helvetica-condensed font-bold uppercase">Takeaway</span>',
            '<span class="text-lewrap-off-black text-xl font-helvetica-condensed font-bold uppercase">Catering Available</span>',
        ]}
    />
</div>
