---
import Button from "./atoms/Button.astro";

interface Props {
    heading?: string;
    text?: string;
    image?: string;
    buttonText?: string;
    buttonLink?: string;
}

const { heading, text, image, buttonText, buttonLink } = Astro.props;
---

<div class="relative">
    <section
        class="w-[95%] mx-auto bg-cover bg-center bg-no-repeat rounded-2xl grid md:grid-cols-2 gap-10 overflow-hidden"
        style="background-image: url('/images/bg-tile-wood.webp'); background-repeat: repeat;"
    >
        <img
            src="/images/elements/cillantro.webp"
            alt="LeWrap"
            class="w-20 h-auto absolute left-1/2 -translate-x-1/2 -top-10 z-20"
        />

        <div>
            <img
                class="w-full h-full object-cover"
                src={image}
                alt={heading}
                data-cms-bind="#franchise_callout.image"
            />
        </div>

        <div
            class="flex flex-col justify-center gap-y-8 p-7 py-16 text-2xl/8 text-lewrap-off-black"
        >
            <h2
                class="text-lewrap-green-dark text-5xl/11 md:text-6xl/14 font-black tracking-tight"
                data-cms-bind="#franchise_callout.heading"
            >
                {heading}
            </h2>

            <div
                class="prose text-2xl/8 text-lewrap-off-black [&_p]:mb-8 [&_p:last-child]:mb-0"
                data-cms-bind="#franchise_callout.text"
                set:html={text}
            />

            {
                buttonText && buttonLink && (
                    <Button href={buttonLink} variant="primary">
                        {buttonText}
                    </Button>
                )
            }
        </div>
    </section>
</div>
