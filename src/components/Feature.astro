---
const { heading, text, image_path, reverse = false, blockIndex } = Astro.props;

// 1. Build the path WITHOUT the '#' hash.
// This points directly to the data structure: page_blocks[0], page_blocks[1]...
const bindBase = blockIndex !== undefined ? `page_blocks[${blockIndex}]` : null;
---

<section
    class="py-12 px-6 max-w-4xl mx-auto grid md:grid-cols-2 gap-8 items-center"
>
    <div
        class={`max-w-xl mx-auto flex flex-col gap-y-8 py-16 ${reverse ? "md:order-2" : ""}`}
    >
        {
            heading && (
                <h2
                    class="text-lewrap-green-dark text-5xl/11 md:text-6xl/14 font-black tracking-tight"
                    data-cms-bind={bindBase ? `${bindBase}.heading` : null}
                >
                    {heading}
                </h2>
            )
        }

        <div class="prose text-2xl/8 text-lewrap-off-black [&_p]:mb-8">
            <div
                set:html={text}
                data-cms-options='{ "format": "html" }'
                data-cms-bind={bindBase ? `${bindBase}.text` : null}
            />
        </div>
    </div>

    {
        image_path && (
            <div class={reverse ? "md:order-1" : ""}>
                <img
                    src={image_path}
                    alt={heading || "Feature Image"}
                    class="w-full aspect-square object-cover rounded-lg shadow-sm"
                    data-cms-bind={bindBase ? `${bindBase}.image_path` : null}
                />
            </div>
        )
    }
</section>
