---
const { heading, text, image_path, reverse, blockIndex } = Astro.props;

// This string points CloudCannon to the exact data in the array
// e.g., "#page_blocks.0"
const bind = blockIndex !== undefined ? `#page_blocks.${blockIndex}` : null;
---

<div
    class={`flex flex-col md:flex-row gap-8 py-12 ${reverse ? "md:flex-row-reverse" : ""}`}
>
    <div class="w-full md:w-1/2">
        {
            image_path && (
                <img
                    src={image_path}
                    alt={heading || "Feature"}
                    class="w-full h-auto rounded-lg shadow-md"
                    data-cms-bind={bind ? `${bind}.image_path` : null}
                />
            )
        }
    </div>

    <div class="w-full md:w-1/2 flex flex-col justify-center">
        {
            heading && (
                <h2
                    class="text-3xl font-bold mb-4"
                    data-cms-bind={bind ? `${bind}.heading` : null}
                >
                    {heading}
                </h2>
            )
        }

        {
            text && (
                <div
                    class="prose max-w-none"
                    set:html={text}
                    data-cms-bind={bind ? `${bind}.text` : null}
                />
            )
        }
    </div>
</div>
