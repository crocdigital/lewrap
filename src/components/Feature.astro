---
const { heading, text, image_path, reverse = false } = Astro.props;
---

<section
    class="py-12 px-6 max-w-4xl mx-auto grid md:grid-cols-2 gap-8 items-center"
>
    <div
        class={`max-w-xl mx-auto flex flex-col gap-y-8 py-16 ${reverse ? "md:order-2" : ""}`}
    >
        {
            heading && (
                <h2 class="text-5xl font-black tracking-tight text-gray-900">
                    {heading}
                </h2>
            )
        }

        {/* The 'prose' class handles the formatting of the HTML text */}
        <div class="prose prose-lg text-gray-600 space-y-6">
            <div set:html={text} />
        </div>
    </div>

    {
        image_path && (
            <div class={reverse ? "md:order-1" : ""}>
                <img
                    src={image_path}
                    alt={heading || "Feature Image"}
                    class="w-full aspect-square object-cover rounded-lg shadow-sm"
                />
            </div>
        )
    }
</section>
