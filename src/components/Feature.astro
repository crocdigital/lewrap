---
const { heading, text, image_path, reverse = false } = Astro.props;
---

<!-- <section
    class="py-12 px-6 max-w-4xl mx-auto grid md:grid-cols-2 gap-8 items-center"
> -->
<section class="rounded-2xl grid md:grid-cols-2">
    <div
        class={`max-w-xl mx-auto flex flex-col gap-y-8 py-16 ${reverse ? "md:order-2" : ""}`}
    >
        <h2
            class="text-lewrap-green-dark text-5xl/11 md:text-6xl/14 font-black tracking-tight"
        >
            {heading}
        </h2>

        <div class="prose text-2xl/8 text-lewrap-off-black">
            <div class="space-y-8" set:html={text} />
        </div>
    </div>

    {
        image_path && (
            <div class={reverse ? "md:order-1" : ""}>
                <img
                    src={image_path}
                    alt={heading}
                    class="w-full aspect-square object-cover rounded-2xl"
                />
            </div>
        )
    }
</section>
