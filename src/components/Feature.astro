---
// src/components/feature.astro (or wherever this component lives)
const { heading, text, image_path, reverse } = Astro.props;
---

<div
    class={`flex flex-col md:flex-row gap-8 py-12 ${reverse ? "md:flex-row-reverse" : ""}`}
>
    <div class="w-full md:w-1/2">
        {
            image_path && (
                <img
                    src={image_path}
                    alt={heading || "Feature image"}
                    class="w-full h-auto rounded-lg shadow-md"
                />
            )
        }
    </div>

    <div class="w-full md:w-1/2 flex flex-col justify-center">
        {heading && <h2 class="text-3xl font-bold mb-4">{heading}</h2>}

        {text && <div class="prose max-w-none" set:html={text} />}
    </div>
</div>
