<section class="my-12">
  <div class="container mx-auto px-4">
    <div
      id="insta-feed"
      class="grid grid-cols-2 md:grid-cols-5 gap-4 min-h-[200px]"
    >
    </div>
  </div>
</section>

<script>
  const businessId = "17841404569950384";
  const token =
    "EAATutGGg9KQBQXQukQhs1nfkYzbAl9uoTZCfJfp9bvINlxyZAOJhlR34VnMjvVHteHVN7tYwcjLmv93xTO0zrSf2fZA5JnIdUEkwPHBstBlzBSZArNtdZABPGJRdeNnSUMXLHZCRCAZAk3H6JRWjQ0yKmZB9XVMPW8ZCv1QMy6y9c7bY9MwjH2NKgkZB4OvomwTgZDZD";
  const fields = "media_type,media_url,thumbnail_url,permalink";
  const limit = 6;

  let feedLoaded = false;

  async function initInstaFeed() {
    const container = document.getElementById("insta-feed");

    if (!container || feedLoaded || container.hasChildNodes()) return;

    feedLoaded = true;

    try {
      const url = `https://graph.facebook.com/v19.0/${businessId}/media?fields=${fields}&access_token=${token}&limit=${limit}`;
      const response = await fetch(url);

      if (!response.ok) throw new Error(`API Error: ${response.statusText}`);

      const data = await response.json();

      if (data?.data) {
        container.innerHTML = "";

        data.data.forEach((post: any, i: number) => {
          const imageUrl =
            post.media_type === "VIDEO" ? post.thumbnail_url : post.media_url;
          if (!imageUrl) return;

          const link = document.createElement("a");
          link.href = post.permalink;
          link.target = "_blank";
          link.rel = "noopener noreferrer";
          link.setAttribute("aria-label", "View on Instagram");

          let classString =
            "block relative aspect-square bg-gray-100 group opacity-0 translate-y-8 transition-all duration-700 ease-out";
          if (i === 5) classString += " md:hidden";

          link.className = classString;
          link.style.transitionDelay = `${i * 100}ms`;

          const img = document.createElement("img");
          img.src = imageUrl;
          img.alt = "Instagram Post";
          img.loading = "lazy";
          img.className =
            "w-full h-full object-cover transition-all duration-500 group-hover:scale-110 rounded-xl";

          link.appendChild(img);
          container.appendChild(link);
        });

        requestAnimationFrame(() => {
          const items = container.querySelectorAll("a");
          items.forEach((item) =>
            item.classList.remove("opacity-0", "translate-y-8"),
          );
        });
      }
    } catch (error) {
      console.error("Instagram Feed Error:", error);
      if (container.parentElement)
        container.parentElement.style.display = "none";
    }
  }

  function setupLazyLoad() {
    const container = document.getElementById("insta-feed");
    if (!container) return;

    // Check if already in viewport on page load
    const rect = container.getBoundingClientRect();
    const isInViewport = rect.top < window.innerHeight + 400; // Same as rootMargin

    if (isInViewport) {
      // Already visible, load immediately
      initInstaFeed();
    } else {
      // Not visible yet, use observer
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              initInstaFeed();
              observer.disconnect();
            }
          });
        },
        {
          rootMargin: "400px",
          threshold: 0,
        },
      );

      observer.observe(container);
    }
  }

  // Reset feedLoaded flag on new page
  document.addEventListener("astro:before-preparation", () => {
    feedLoaded = false;
  });

  setupLazyLoad();
  document.addEventListener("astro:page-load", setupLazyLoad);
</script>
