<section class="my-12">
    <div class="container mx-auto px-4">
        <div
            id="insta-feed"
            class="grid grid-cols-2 md:grid-cols-5 gap-4 min-h-[200px]"
        >
        </div>
    </div>
</section>

<script>
  const businessId = "17841404569950384";

    const token =
        "EAATutGGg9KQBQXQukQhs1nfkYzbAl9uoTZCfJfp9bvINlxyZAOJhlR34VnMjvVHteHVN7tYwcjLmv93xTO0zrSf2fZA5JnIdUEkwPHBstBlzBSZArNtdZABPGJRdeNnSUMXLHZCRCAZAk3H6JRWjQ0yKmZB9XVMPW8ZCv1QMy6y9c7bY9MwjH2NKgkZB4OvomwTgZDZD";

  const fields = "media_type,media_url,thumbnail_url,permalink";
  const limit = 6; 

  // We wrap the logic in a named function so we can run it multiple times
  async function initInstaFeed() {
    const container = document.getElementById('insta-feed');
    
    // If we're on a page without the feed, stop.
    // If the feed is already populated (from a previous run), stop.
    if (!container || container.hasChildNodes()) return;

    try {
      const url = `https://graph.facebook.com/v19.0/${businessId}/media?fields=${fields}&access_token=${token}&limit=${limit}`;
      const response = await fetch(url);
      
      if (!response.ok) throw new Error(`API Error: ${response.statusText}`);

      const data = await response.json();

      if (data && data.data) {
        container.innerHTML = '';

        for (let i = 0; i < data.data.length; i++) {
          const post = data.data[i];
          const imageUrl = post.media_type === 'VIDEO' ? post.thumbnail_url : post.media_url;

          if (imageUrl) {
            const link = document.createElement('a');
            link.href = post.permalink;
            link.target = "_blank";
            link.setAttribute('aria-label', 'View on Instagram');

            // Animation classes
            let classString = "block relative aspect-square bg-gray-100 group opacity-0 translate-y-8 transition-all duration-700 ease-out";
            
            // Hide 6th item on desktop
            if (i === 5) classString += " md:hidden";
            
            link.className = classString;
            link.style.transitionDelay = `${i * 100}ms`;

            const img = document.createElement('img');
            img.src = imageUrl;
            img.alt = "Instagram Post";
            img.loading = "lazy";
            
            // Image styling
            img.className = "w-full h-full object-cover transition-all duration-500 group-hover:scale-110 rounded-xl group-hover:rounded-none";

            link.appendChild(img);
            container.appendChild(link);
          }
        }

        // --- TRIGGER ANIMATION ---
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const items = container.querySelectorAll('a');
              items.forEach(item => {
                item.classList.remove('opacity-0', 'translate-y-8');
              });
              observer.unobserve(container);
            }
          });
        }, { threshold: 0.1 });

        observer.observe(container);
      }
    } catch (error) {
      console.error("Instagram Feed Error:", error);
      if (container.parentElement) container.parentElement.style.display = 'none';
    }
  }

  // Run on initial load
  initInstaFeed();

  // Run on view transitions (Astro navigation)
  document.addEventListener('astro:page-load', initInstaFeed);
</script>
