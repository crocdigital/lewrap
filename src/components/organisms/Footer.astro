---
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
import leWrapLogo from "../../assets/lewrap-w.svg";
---

<div class="max-w-screen-2xl w-full mx-auto">
    <footer
        class="w-[95%] mx-auto bg-lewrap-green rounded-b-2xl px-10 py-20 mb-8 flex flex-col gap-y-10 text-white"
    >
        <section>
            <div class="grid grid-cols-2 md:grid-cols-8 gap-x-6">
                <div class="col-span-2 md:col-span-1">
                    <a href="/">
                        <img
                            src={leWrapLogo.src}
                            alt="LeWrap"
                            class="mx-auto md:mx-0 w-[157px] h-[46px]"
                        />
                    </a>

                    {/* Social Icons - Desktop */}
                    <div
                        class="flex gap-x-6 justify-center md:justify-start shrink-0 nav-socials-desktop"
                    >
                        <a
                            href="https://www.instagram.com/lewrap_official"
                            target="_blank"
                            class="hover:opacity-70 transition-opacity"
                        >
                            <svg
                                width="32"
                                height="32"
                                viewBox="0 0 22 21"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <g clip-path="url(#clip0_4_53_d)">
                                    <path
                                        d="M11.0021 5.11587C8.01892 5.11587 5.61271 7.51975 5.61271 10.5C5.61271 13.4803 8.01892 15.8841 11.0021 15.8841C13.9852 15.8841 16.3914 13.4803 16.3914 10.5C16.3914 7.51975 13.9852 5.11587 11.0021 5.11587ZM11.0021 14.0004C9.07427 14.0004 7.49828 12.4306 7.49828 10.5C7.49828 8.5694 9.06958 6.99961 11.0021 6.99961C12.9345 6.99961 14.5058 8.5694 14.5058 10.5C14.5058 12.4306 12.9298 14.0004 11.0021 14.0004ZM17.8689 4.89563C17.8689 5.59383 17.306 6.15146 16.6118 6.15146C15.913 6.15146 15.3548 5.58914 15.3548 4.89563C15.3548 4.20211 15.9177 3.6398 16.6118 3.6398C17.306 3.6398 17.8689 4.20211 17.8689 4.89563ZM21.4383 6.1702C21.3586 4.48795 20.974 2.99782 19.7404 1.77011C18.5115 0.542397 17.0199 0.15815 15.336 0.0738034C13.6006 -0.0246011 8.39885 -0.0246011 6.66338 0.0738034C4.98419 0.153464 3.49263 0.537711 2.25904 1.76542C1.02545 2.99314 0.645518 4.48326 0.56109 6.16551C0.46259 7.89931 0.46259 13.096 0.56109 14.8298C0.640828 16.512 1.02545 18.0022 2.25904 19.2299C3.49263 20.4576 4.9795 20.8418 6.66338 20.9262C8.39885 21.0246 13.6006 21.0246 15.336 20.9262C17.0199 20.8465 18.5115 20.4623 19.7404 19.2299C20.9693 18.0022 21.3539 16.512 21.4383 14.8298C21.5368 13.096 21.5368 7.90399 21.4383 6.1702ZM19.1963 16.6901C18.8304 17.6086 18.1222 18.3161 17.1981 18.6863C15.8145 19.2346 12.5311 19.1081 11.0021 19.1081C9.47296 19.1081 6.18495 19.2299 4.80596 18.6863C3.88663 18.3208 3.17837 17.6132 2.80782 16.6901C2.25904 15.3078 2.38568 12.0276 2.38568 10.5C2.38568 8.97239 2.26373 5.68755 2.80782 4.30988C3.17368 3.39144 3.88193 2.68387 4.80596 2.31368C6.18964 1.76542 9.47296 1.89194 11.0021 1.89194C12.5311 1.89194 15.8192 1.77011 17.1981 2.31368C18.1175 2.67918 18.8257 3.38676 19.1963 4.30988C19.7451 5.69223 19.6184 8.97239 19.6184 10.5C19.6184 12.0276 19.7451 15.3124 19.1963 16.6901Z"
                                        fill="white"></path>
                                </g>
                                <defs>
                                    <clipPath id="clip0_4_53_d">
                                        <rect
                                            width="21.5122"
                                            height="21"
                                            fill="white"></rect>
                                    </clipPath>
                                </defs>
                            </svg>
                        </a>
                        <a
                            href="https://www.tiktok.com/@lewrap"
                            target="_blank"
                            class="hover:opacity-70 transition-opacity"
                        >
                            <svg
                                width="28"
                                height="32"
                                viewBox="0 0 19 21"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M15.5778 4.20913C14.4467 3.47161 13.6306 2.29118 13.3759 0.915984C13.3209 0.618941 13.2903 0.312934 13.2903 0H9.68018L9.67407 14.4687C9.61376 16.0892 8.28012 17.3894 6.64537 17.3894C6.13726 17.3894 5.65889 17.2627 5.23757 17.0406C4.27147 16.5325 3.61015 15.52 3.61015 14.355C3.61015 12.6816 4.9719 11.3198 6.64496 11.3198C6.95749 11.3198 7.25698 11.3716 7.54017 11.46V7.77446C7.24679 7.73412 6.94893 7.70967 6.64496 7.70967C2.98102 7.70967 0 10.6903 0 14.355C0 16.603 1.12298 18.5927 2.83719 19.7955C3.91616 20.5538 5.22942 21 6.64537 21C10.3097 21 13.2903 18.019 13.2903 14.355V7.01779C14.7063 8.03401 16.4413 8.63299 18.3136 8.63299V5.02243C17.3051 5.02243 16.3659 4.72294 15.5778 4.20913Z"
                                    fill="white"></path>
                            </svg>
                        </a>
                        <a
                            href="https://www.facebook.com/lewrapaus"
                            target="_blank"
                            class="hover:opacity-70 transition-opacity"
                        >
                            <svg
                                width="17"
                                height="32"
                                viewBox="0 0 12 21"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <g clip-path="url(#clip0_4_48_d)">
                                    <path
                                        d="M10.4015 11.8125L10.9787 8.01199H7.36971V5.54572C7.36971 4.50598 7.87385 3.49248 9.49019 3.49248H11.1309V0.256758C11.1309 0.256758 9.642 0 8.21847 0C5.24639 0 3.30371 1.82027 3.30371 5.11547V8.01199H0V11.8125H3.30371V21H7.36971V11.8125H10.4015Z"
                                        fill="white"></path>
                                </g>
                                <defs>
                                    <clipPath id="clip0_4_48_d">
                                        <rect
                                            width="11.2683"
                                            height="21"
                                            fill="white"></rect>
                                    </clipPath>
                                </defs>
                            </svg>
                        </a>
                    </div>
                </div>

                <div class="col-span-2 md:col-span-4">
                    <h3
                        class="font-cocogoose text-4xl md:text-5xl leading-tight opacity-30 text-center md:text-left -mt-1"
                    >
                        Fresh, high quality, delicious meals without the wait.
                    </h3>
                </div>

                <div class="col-span-1 hidden md:block"></div>

                <div class="col-span-1 flex flex-col gap-y-2">
                    <a
                        href="#"
                        class={`${pathname === "#" ? "text-white pointer-events-none" : "font-helvetica-condensed font-black text-white/70 hover:text-white"} duration-200`}
                    >
                        Order Now
                    </a>
                    <a
                        href="/locations"
                        class={`${pathname === "/locations" ? "text-white pointer-events-none" : "text-white/70 hover:text-white"} duration-200`}
                    >
                        Locations
                    </a>
                    <a
                        href="/our-food"
                        class={`${pathname === "/our-food" ? "text-white pointer-events-none" : "text-white/70 hover:text-white"} duration-200`}
                    >
                        Our food
                    </a>
                    <a
                        href="/nutrition"
                        class={`${pathname === "/nutrition" ? "text-white pointer-events-none" : "text-white/70 hover:text-white"} duration-200`}
                    >
                        Nutrition
                    </a>
                    <a
                        href="#"
                        class={`${pathname === "#" ? "text-white pointer-events-none" : "text-white/70 hover:text-white"} duration-200`}
                    >
                        Catering
                    </a>
                    <a
                        href="#"
                        class={`${pathname === "#" ? "text-white pointer-events-none" : "text-white/70 hover:text-white"} duration-200`}
                    >
                        FAQs
                    </a>
                    <a
                        href="#"
                        class={`${pathname === "#" ? "text-white pointer-events-none" : "text-white/70 hover:text-white"} duration-200`}
                    >
                        Our story
                    </a>
                </div>

                <div class="col-span-1 flex flex-col gap-y-2">
                    <a
                        href="#"
                        class={`${pathname === "#" ? "text-white pointer-events-none" : "font-helvetica-condensed font-black text-white/70 hover:text-white"} duration-200`}
                    >
                        Own a store
                    </a>
                    <a
                        href="#"
                        class={`${pathname === "#" ? "text-white pointer-events-none" : "text-white/70 hover:text-white"} duration-200`}
                    >
                        Community
                    </a>
                    <a
                        href="#"
                        class={`${pathname === "#" ? "text-white pointer-events-none" : "text-white/70 hover:text-white"} duration-200`}
                    >
                        Newsroom
                    </a>
                    <a
                        href="#"
                        class={`${pathname === "#" ? "text-white pointer-events-none" : "text-white/70 hover:text-white"} duration-200`}
                    >
                        Work with us
                    </a>
                    <a
                        href="#"
                        class={`${pathname === "#" ? "text-white pointer-events-none" : "text-white/70 hover:text-white"} duration-200`}
                    >
                        Contact LeWrap
                    </a>
                    <a
                        href="#"
                        class={`${pathname === "#" ? "text-white pointer-events-none" : "text-white/70 hover:text-white"} duration-200`}
                    >
                        Policies
                    </a>
                </div>
            </div>

            <div
                class="flex flex-col md:flex-row mx-auto mt-20 justify-center text-center gap-2 text-white"
            >
                <p class="text-white/70">
                    &copy; {new Date().getFullYear()} Retail Systems Group Ltd. All
                    rights reserved.
                </p>
                <p
                    class="flex items-center gap-x-1 text-white/70 mx-auto md:mx-0"
                >
                    Made with{" "}
                    <svg
                        width="12"
                        height="10"
                        viewBox="0 0 15 13"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path
                            d="M3.85979 0C2.86643 0 1.87312 0.389074 1.12359 1.17349C-0.375497 2.74228 -0.373564 5.25615 1.12359 6.82599L6.84579 12.827C6.89788 12.8817 6.96052 12.9252 7.02992 12.9549C7.09933 12.9847 7.17404 13 7.24954 13C7.32504 13 7.39976 12.9847 7.46916 12.9549C7.53856 12.9252 7.60121 12.8817 7.6533 12.827C9.56213 10.8294 11.4724 8.82946 13.3813 6.83179C14.8804 5.26297 14.8804 2.74812 13.3813 1.1793C11.8822 -0.38952 9.40798 -0.389553 7.90891 1.1793L7.25244 1.85899L6.596 1.17349C5.84645 0.389077 4.85314 0 3.85979 0ZM3.85979 1.09216C4.55321 1.09216 5.25133 1.3779 5.79431 1.94613L6.85161 3.05572C6.9037 3.11037 6.96052 3.15388 7.03574 3.18361C7.10514 3.21334 7.17985 3.22866 7.25535 3.22866C7.33085 3.22866 7.40556 3.21334 7.47497 3.18361C7.54437 3.15388 7.60701 3.11037 7.6591 3.05572L8.7106 1.95194C9.79653 0.815454 11.4879 0.81548 12.5738 1.95194C13.6597 3.0884 13.6597 4.9285 12.5738 6.06496C10.8003 7.92101 9.02596 9.77427 7.25244 11.6303L1.93108 6.05916C0.845729 4.9211 0.845153 3.08256 1.93108 1.94613C2.47404 1.3779 3.16636 1.09216 3.85979 1.09216Z"
                            fill="#fff"></path>
                    </svg>
                    {" "}by <a
                        href="https://crocdigital.com.au"
                        target="_blank"
                        class="text-white">Croc Digital</a
                    >
                </p>
            </div>
        </section>
    </footer>
</div>
