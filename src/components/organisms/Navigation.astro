        style="width: auto; transition: width 0.5s cubic-bezier(0.22, 1, 0.36, 1);"
    >
        {/* Logo */}
        <a href="/" class="shrink-0">
            <Image
                src={leWrapLogo}
                alt="LeWrap"
                class="w-[90px] md:w-[130px] h-auto"
