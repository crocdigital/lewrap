{/* Mobile Menu Dropdown - Full Screen */}
<div
    id="mobile-menu-overlay"
    class="md:hidden fixed inset-0 z-40 bg-white transition-opacity duration-300 opacity-0 pointer-events-none"
>
    <div
        class="flex flex-col items-center justify-center h-full px-8 gap-5 pt-24 capitalize"
    >
        <a
            href="/our-story"
            class:list={[
                "duration-200 text-2xl font-helvetica-condensed font-bold mobile-link",
                pathname === "/our-story"
                    ? "text-lewrap-green"
                    : "text-lewrap-green-dark hover:text-lewrap-green",
            ]}
        >
            Our story
        </a>
        <a
            href="/locations"
            class:list={[
                "duration-200 text-2xl font-helvetica-condensed font-bold mobile-link",
                pathname === "/locations"
                    ? "text-lewrap-green"
                    : "text-lewrap-green-dark hover:text-lewrap-green",
            ]}
        >
            Locations
        </a>
        <a
            href="/our-food"
            class:list={[
                "duration-200 text-2xl font-helvetica-condensed font-bold mobile-link",
                pathname === "/our-food"
                    ? "text-lewrap-green"
                    : "text-lewrap-green-dark hover:text-lewrap-green",
            ]}
        >
            Our food
        </a>
        <a
            href="/nutrition"
            class:list={[
                "duration-200 text-2xl font-helvetica-condensed font-bold mobile-link",
                pathname === "/nutrition"
                    ? "text-lewrap-green"
                    : "text-lewrap-green-dark hover:text-lewrap-green",
            ]}
        >
            Nutrition
        </a>
        <a
            href="/catering"
            class:list={[
                "duration-200 text-2xl font-helvetica-condensed font-bold mobile-link",
                pathname === "/catering"
                    ? "text-lewrap-green"
                    : "text-lewrap-green-dark hover:text-lewrap-green",
            ]}
        >
            Catering
        </a>
        <a
            href="/work-with-us"
            class:list={[
                "dur    ation-200 text-2xl font-helvetica-condensed font-bold mobile-link",
                pathname === "/work-with-us"
                    ? "text-lewrap-green"
                    : "text-lewrap-green-dark hover:text-lewrap-green",
            ]}
        >
            Work With Us
        </a>
        <a
            href="/own-a-store"
            class:list={[
                "duration-200 text-2xl font-helvetica-condensed font-bold mobile-link",
                pathname === "/own-a-store"
                    ? "text-lewrap-green"
                    : "text-lewrap-green-dark hover:text-lewrap-green",
            ]}
        >
            Own a store
        </a>

        {/* Order Now Button */}
        <a
            href="https://lewrap.redcatcloud.com.au/app/menu"
            class="px-8 py-4 bg-lewrap-green-dark rounded-full w-full border-4 border-lewrap-green text-white font-cocogoose uppercase duration-200 text-2xl hover:bg-lewrap-green hover:scale-105 text-center mt-4 mobile-link"
            target="_blank"
        >
            Order now
        </a>
    </div>
</div>

<script>
    function initNavigation() {
        const nav = document.getElementById("main-nav");
        if (!nav) return;

        const mobileBtn = document.getElementById("mobile-menu-btn");
        const mobileMenuOverlay = document.getElementById(
            "mobile-menu-overlay",
        );
        const hamburgerLine1 = mobileBtn?.querySelector(".hamburger-line-1");
        const hamburgerLine2 = mobileBtn?.querySelector(".hamburger-line-2");
        const hamburgerLine3 = mobileBtn?.querySelector(".hamburger-line-3");
        const mobileLinks = document.querySelectorAll(".mobile-link");

        let isMobileMenuOpen = false;
        let isScrolled = window.scrollY > 50;
        let contentWidth = 0;
        let expandedWidth = 0;
        let isMobile = window.innerWidth < 768;

        function toggleMobileMenu(open: boolean) {
            isMobileMenuOpen = open;
            if (open) {
                // Open menu
                mobileMenuOverlay?.classList.remove(
                    "opacity-0",
                    "pointer-events-none",
                );
                mobileMenuOverlay?.classList.add(
                    "opacity-100",
                    "pointer-events-auto",
                );

                // Animate hamburger
                hamburgerLine1?.classList.add("rotate-45", "translate-y-[8px]");
                hamburgerLine2?.classList.add("opacity-0");
                hamburgerLine3?.classList.add(
                    "-rotate-45",
                    "-translate-y-[8px]",
                    "w-full",
                );
                hamburgerLine3?.classList.remove("w-[80%]");
            } else {
                // Close menu
                mobileMenuOverlay?.classList.remove(
                    "opacity-100",
                    "pointer-events-auto",
                );
                mobileMenuOverlay?.classList.add(
                    "opacity-0",
                    "pointer-events-none",
                );

                // Reset hamburger
                hamburgerLine1?.classList.remove(
                    "rotate-45",
                    "translate-y-[8px]",
                );
                hamburgerLine2?.classList.remove("opacity-0");
                hamburgerLine3?.classList.remove(
                    "-rotate-45",
                    "-translate-y-[8px]",
                    "w-full",
                );
                hamburgerLine3?.classList.add("w-[80%]");
            }
        }

        // Event Listeners
        mobileBtn?.addEventListener("click", () => {
            toggleMobileMenu(!isMobileMenuOpen);
        });

        mobileLinks.forEach((link) => {
            link.addEventListener("click", () => {
                toggleMobileMenu(false);
            });
        });

        // Width calculation logic
        function updateWidths() {
            if (!nav) return;

            isMobile = window.innerWidth < 768;

            // Calculate natural content width
            const children = Array.from(nav.children).filter(
                (child) => !child.classList.contains("nav-spacer"),
            );

            // Sum up widths
            const childrenWidth = children.reduce((total, child) => {
                return total + (child as HTMLElement).offsetWidth;
            }, 0);

            // Add padding (matches React: 150)
            const padding = 150;
            contentWidth = childrenWidth + padding;

            // Calculate expanded width (95% of viewport, max 1400)
            const ninetyFivePercent = window.innerWidth * 0.95;
            const maxAllowed = 1400;
            expandedWidth = Math.min(ninetyFivePercent, maxAllowed);

            updateNavState();

            // Fade in nav after initial calculation
            nav.classList.remove("opacity-0");
        }

        function updateNavState() {
            if (!nav) return;
            if (isMobile) {
                nav.style.width = `${expandedWidth}px`;
            } else {
                nav.style.width = isScrolled
                    ? `${contentWidth}px`
                    : `${expandedWidth}px`;
            }
        }

        function handleScroll() {
            const newIsScrolled = window.scrollY > 50;
            if (newIsScrolled !== isScrolled) {
                isScrolled = newIsScrolled;
                updateNavState();
            }
        }

        // Initialize
        updateWidths();
        window.addEventListener("resize", updateWidths);
        window.addEventListener("scroll", handleScroll);

        // Cleanup function for view transitions if needed (Astro handles scripts by default but listener cleanup is good practice)
        // Since we are using View Transitions, looking for 'astro:before-swap' or similar might be needed if this persists?
        // But since this component is re-rendered, the script re-runs.
        // We should just ensure we don't duplicate listeners if the framework doesn't clean them up, but a fresh run is safe.
    }

    // Run on load and after view transitions
    initNavigation();
    document.addEventListener("astro:page-load", initNavigation);
</script>
