---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Button from "./atoms/Button.astro";

const allLocations = (await getCollection(
    "locations",
)) as CollectionEntry<"locations">[];
const sortedLocations = allLocations.sort((a, b) =>
    a.data.name.localeCompare(b.data.name),
);

const RECAPTCHA_SITE_KEY = "6Lex21IsAAAAAOsum82vt4qkrGeLYRSD6EDX4aqy";
---

<script src="https://www.google.com/recaptcha/api.js" async defer></script>

<script>
    declare const grecaptcha: any;

    function renderRecaptcha() {
        const recaptchaContainer = document.querySelector(".g-recaptcha");
        if (!recaptchaContainer) return;
        if (recaptchaContainer.children.length > 0) return;

        const checkAndRender = () => {
            if (typeof grecaptcha !== "undefined" && grecaptcha.render) {
                try {
                    grecaptcha.render(recaptchaContainer, {
                        sitekey:
                            recaptchaContainer.getAttribute("data-sitekey"),
                    });
                } catch (e) {
                    console.log("reCAPTCHA already rendered or error:", e);
                }
            } else {
                setTimeout(checkAndRender, 100);
            }
        };

        checkAndRender();
    }

    renderRecaptcha();
    document.addEventListener("astro:page-load", renderRecaptcha);
</script>

<style>
    .field-reveal {
        display: grid;
        grid-template-rows: 0fr;
        opacity: 0;
        transform: translateY(-6px);
        transition:
            grid-template-rows 0.3s ease,
            opacity 0.3s ease,
            transform 0.3s ease;
        pointer-events: none;
    }

    .field-reveal > div {
        overflow: hidden;
    }

    .field-reveal.visible > div {
        overflow: visible;
    }

    .field-reveal.visible {
        grid-template-rows: 1fr;
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }
</style>

<form class="p-8 md:p-12" id="work-with-us-form">
    <h2
        class="text-3xl/7 md:text-4xl font-bold text-lewrap-green-dark text-center mb-8"
    >
        Apply to work with us
    </h2>

    <div class="max-w-screen-md mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
        {/* Your name */}
        <div class="md:col-span-2">
            <label
                for="name"
                class="block text-lg font-medium text-lewrap-off-black mb-2"
            >
                Your name <span class="text-red-500">*</span>
            </label>
            <input
                type="text"
                id="name"
                name="name"
                required
                class="bg-white w-full p-4 border border-gray-300 rounded-lg focus:ring-2 focus:ring-lewrap-green focus:border-transparent focus:outline-none"
            />
        </div>

        {/* Your email */}
        <div class="md:col-span-2">
            <label
                for="email"
                class="block text-lg font-medium text-lewrap-off-black mb-2"
            >
                Your email <span class="text-red-500">*</span>
            </label>
            <input
                type="email"
                id="email"
                name="email"
                required
                class="bg-white w-full p-4 border border-gray-300 rounded-lg focus:ring-2 focus:ring-lewrap-green focus:border-transparent focus:outline-none"
            />
        </div>

        {/* Best contact number */}
        <div>
            <label
                for="phone"
                class="block text-lg font-medium text-lewrap-off-black mb-2"
            >
                Best contact number <span class="text-red-500">*</span>
            </label>
            <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="bg-white w-full p-4 border border-gray-300 rounded-lg focus:ring-2 focus:ring-lewrap-green focus:border-transparent focus:outline-none"
            />
        </div>

        {/* Apply to work at - radio buttons */}
        <div>
            <label class="block text-lg font-medium text-lewrap-off-black mb-2">
                Apply to work at <span class="text-red-500">*</span>
            </label>
            <div class="space-y-3">
                <label class="flex items-center cursor-pointer">
                    <input
                        type="radio"
                        name="location_preference"
                        value="headquarters"
                        required
                        class="w-5 h-5 text-lewrap-green focus:ring-lewrap-green"
                    />
                    <span class="ml-3 text-lewrap-off-black"
                        >LeWrap Head Office</span
                    >
                </label>
                <label class="flex items-center cursor-pointer">
                    <input
                        type="radio"
                        name="location_preference"
                        value="store"
                        id="store-radio"
                        required
                        class="w-5 h-5 text-lewrap-green focus:ring-lewrap-green"
                    />
                    <span class="ml-3 text-lewrap-off-black">Closest store</span
                    >
                </label>
            </div>
        </div>

        {/* Conditional store dropdown - fades in */}
        <div class="md:col-span-2 field-reveal" id="store-dropdown">
            <div>
                <label
                    for="preferred_store"
                    class="block text-lg font-medium text-lewrap-off-black mb-2"
                >
                    Choose the store closest to you <span class="text-red-500"
                        >*</span
                    >
                </label>
                <select
                    id="preferred_store"
                    name="preferred_store"
                    class="bg-white w-full p-4.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-lewrap-green focus:border-transparent appearance-none focus:outline-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%23CBCBCB%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:30px_30px] bg-[right_0.5rem_center] bg-no-repeat pr-12"
                >
                    <option value="">Select a store</option>
                    {
                        sortedLocations.map((location) => (
                            <option
                                value={
                                    location.data.email || location.data.name
                                }
                            >
                                {location.data.name}
                            </option>
                        ))
                    }
                </select>
            </div>
        </div>

        {/* I'm interested in - hidden until radio selected, then fades in */}
        <div class="md:col-span-2 field-reveal" id="position-field">
            <div>
                <label
                    for="position"
                    class="block text-lg font-medium text-lewrap-off-black mb-2"
                >
                    I'm interested in <span class="text-red-500">*</span>
                </label>
                <select
                    id="position"
                    name="position"
                    required
                    class="bg-white w-full p-4.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-lewrap-green focus:border-transparent focus:outline-none appearance-none focus:outline-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%23CBCBCB%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:30px_30px] bg-[right_0.5rem_center] bg-no-repeat pr-12"
                >
                    <option value="">Select a position</option>
                    <option value="Front of house">Front of house</option>
                    <option value="Back of house">Back of house</option>
                    <option value="Management">Management</option>
                    <option value="Other">Other</option>
                </select>
            </div>
        </div>

        {/* File upload */}
        <div class="md:col-span-2">
            <label
                for="resume"
                class="block text-lg font-medium text-lewrap-off-black mb-2"
            >
                Choose file <span class="text-red-500">*</span>
            </label>
            <input
                type="file"
                id="resume"
                name="resume"
                accept=".pdf,.doc,.docx"
                required
                class="bg-white w-full p-4 border border-gray-300 rounded-lg focus:ring-2 focus:ring-lewrap-green focus:border-transparent file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-lewrap-green file:text-white hover:file:bg-lewrap-green-dark"
            />
            <p class="mt-2 text-sm text-gray-500">
                We accept PDF, DOC, and DOCX files
            </p>
        </div>

        {/* Additional info */}
        <div class="md:col-span-2">
            <label
                for="message"
                class="block text-lg font-medium text-lewrap-off-black mb-2"
            >
                Any other additional info?
            </label>
            <textarea
                id="message"
                name="message"
                rows="5"
                class="bg-white w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-lewrap-green focus:border-transparent focus:outline-none"
            ></textarea>
        </div>

        {/* reCAPTCHA */}
        <div>
            <div class="g-recaptcha" data-sitekey={RECAPTCHA_SITE_KEY}></div>
        </div>

        {/* Submit button */}
        <div class="md:col-span-2 pt-4">
            <Button type="submit" variant="secondary">Apply now</Button>
        </div>
    </div>
</form>

<script>
    const storeRadio = document.getElementById(
        "store-radio",
    ) as HTMLInputElement;
    const headquartersRadio = document.querySelector(
        'input[value="headquarters"]',
    ) as HTMLInputElement;
    const storeDropdown = document.getElementById(
        "store-dropdown",
    ) as HTMLElement;
    const storeSelect = document.getElementById(
        "preferred_store",
    ) as HTMLSelectElement;
    const positionField = document.getElementById(
        "position-field",
    ) as HTMLElement;
    const positionSelect = document.getElementById(
        "position",
    ) as HTMLSelectElement;

    const storeOptions = [
        { value: "Front of house", label: "Front of house" },
        { value: "Back of house", label: "Back of house" },
        { value: "Management", label: "Management" },
        { value: "Other", label: "Other" },
    ];

    const hqOptions = [
        { value: "Admin", label: "Admin" },
        { value: "Management", label: "Management" },
        { value: "Operations", label: "Operations" },
        { value: "Other", label: "Other" },
    ];

    function updatePositionOptions() {
        const isHQ = headquartersRadio?.checked;
        const options = isHQ ? hqOptions : storeOptions;

        positionSelect.value = "";
        while (positionSelect.options.length > 1) {
            positionSelect.remove(1);
        }
        options.forEach(({ value, label }) => {
            const opt = document.createElement("option");
            opt.value = value;
            opt.textContent = label;
            positionSelect.appendChild(opt);
        });
    }

    function handleLocationChange() {
        const isStore = storeRadio?.checked;

        // Store dropdown: fade in only for "Closest store"
        if (isStore) {
            storeDropdown.classList.add("visible");
            storeSelect.required = true;
        } else {
            storeDropdown.classList.remove("visible");
            storeSelect.required = false;
            storeSelect.value = "";
        }

        // Position field: always reveal once any radio is selected
        positionField.classList.add("visible");

        // Update the options to match the selection
        updatePositionOptions();
    }

    storeRadio?.addEventListener("change", handleLocationChange);
    headquartersRadio?.addEventListener("change", handleLocationChange);

    // Form submission
    const form = document.getElementById(
        "work-with-us-form",
    ) as HTMLFormElement;
    const submitButton = form?.querySelector(
        'button[type="submit"]',
    ) as HTMLButtonElement;

    let messageContainer = document.getElementById("form-message");
    if (!messageContainer) {
        messageContainer = document.createElement("div");
        messageContainer.id = "form-message";
        messageContainer.className = "mt-4 p-4 rounded-lg hidden";
        submitButton.parentElement?.appendChild(messageContainer);
    }

    function showMessage(message: string, type: "success" | "error") {
        if (!messageContainer) return;
        messageContainer.textContent = message;
        messageContainer.className = `mt-4 p-4 rounded-lg ${
            type === "success"
                ? "bg-green-100 text-green-800 border border-green-300"
                : "bg-red-100 text-red-800 border border-red-300"
        }`;
        messageContainer.scrollIntoView({
            behavior: "smooth",
            block: "nearest",
        });
    }

    function hideMessage() {
        if (!messageContainer) return;
        messageContainer.className = "mt-4 p-4 rounded-lg hidden";
    }

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        hideMessage();

        const recaptchaResponse = (window as any).grecaptcha.getResponse();
        if (!recaptchaResponse) {
            showMessage("Please complete the reCAPTCHA verification", "error");
            return;
        }

        const fileInput = document.getElementById("resume") as HTMLInputElement;
        if (!fileInput.files || fileInput.files.length === 0) {
            showMessage("Please upload your resume", "error");
            return;
        }

        const originalButtonText = submitButton.textContent;
        submitButton.disabled = true;
        submitButton.textContent = "Sending...";

        try {
            const formData = new FormData(form);
            formData.append("g-recaptcha-response", recaptchaResponse);

            const response = await fetch("/api/work-with-us", {
                method: "POST",
                body: formData,
            });

            const result = await response.json();

            if (result.success) {
                showMessage(result.message, "success");
                form.reset();
                (window as any).grecaptcha.reset();
                // Hide conditional fields again after reset
                storeDropdown.classList.remove("visible");
                positionField.classList.remove("visible");
                storeSelect.required = false;
            } else {
                showMessage(result.message, "error");
            }
        } catch (error) {
            console.error("Form submission error:", error);
            showMessage(
                "Something went wrong. Please try again or email us directly at info@lewrap.com",
                "error",
            );
        } finally {
            submitButton.disabled = false;
            submitButton.textContent = originalButtonText;
        }
    });
</script>
