---
import Button from "../components/atoms/Button.astro";
const {
    title,
    subtitle,
    hero_bg_type,
    hero_bg_colour,
    hero_bg_image,
    hero_bg_image_mobile,
    hero_button_text,
    hero_button_link,
    hero_button_variant = "primary",
    hero_button_target,
    hero_button_download,
    show_food_cat_links = false,
    show_search = false,
} = Astro.props;

// Convert switch values to proper attributes
const targetAttr = hero_button_target ? "_blank" : undefined;
const downloadAttr = hero_button_download ? true : undefined;

// Determine background style
let backgroundStyle = "";
let showColorBackground = false;

if (hero_bg_type === "color") {
    const colour = hero_bg_colour || "#81b944"; // Fallback to LeWrap green
    backgroundStyle = `background-color: ${colour};`;
    showColorBackground = true;
} else if (
    hero_bg_type === "image" &&
    (hero_bg_image || hero_bg_image_mobile)
) {
    // Image will be rendered as <picture> tag instead
    showColorBackground = false;
}
---

<section
    class="relative flex items-center justify-center mt-10 md:mt-15 w-[95%] mx-auto h-[62vh] md:h-[75vh] rounded-2xl overflow-hidden bg-lewrap-green"
    style={showColorBackground ? backgroundStyle : ""}
>
    {/* Background Image (if selected) */}
    {
        hero_bg_type === "image" && (hero_bg_image || hero_bg_image_mobile) && (
            <picture>
                {/* Mobile version (optional) */}
                {hero_bg_image_mobile && (
                    <source
                        media="(max-width: 768px)"
                        srcset={hero_bg_image_mobile}
                        type="image/webp"
                    />
                )}
                {/* Desktop version (fallback) */}
                <source
                    srcset={hero_bg_image || hero_bg_image_mobile}
                    type="image/webp"
                />
                <img
                    src={hero_bg_image || hero_bg_image_mobile}
                    alt={title || "Hero background"}
                    class="absolute inset-0 w-full h-full object-cover z-0"
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                    width="1920"
                    height="1080"
                />
            </picture>
        )
    }
    {/* Gradient Overlay */}
    <div
        class="absolute inset-0 w-full h-full bg-gradient-to-b from-black/0 to-black/40 z-10"
    >
    </div>
    {/* Content */}
    <div
        class="max-w-[930px] relative z-20 flex flex-col items-center justify-center h-full w-full gap-y-6 px-6"
    >
        {
            title && (
                <h1
                    class="md:w-auto mx-auto text-white text-4xl md:text-[90px] font-bold leading-[100%] tracking-tight text-center"
                    data-editable="text"
                    data-prop="hero_title"
                    data-cms-bind="#hero_title"
                >
                    {title}
                </h1>
            )
        }

        {/* Food Categories (only shows on Our Food page) */}
        {
            show_food_cat_links && (
                <div class="w-full md:w-[75%] flex flex-wrap gap-2 md:gap-4 justify-center">
                    <Button
                        href="#latest-deals"
                        class="btn-lewrap bg-lewrap-green-dark px-4 py-1 text-base leading-loose"
                    >
                        Latest deals
                    </Button>
                    <Button
                        href="#wraps"
                        class="btn-lewrap px-4 py-1 text-base leading-loose"
                    >
                        Wraps
                    </Button>
                    <Button
                        href="#plates"
                        class="btn-lewrap px-4 py-1 text-base leading-loose"
                    >
                        Plates
                    </Button>
                    <Button
                        href="#baguettes"
                        class="btn-lewrap px-4 py-1 text-base leading-loose"
                    >
                        Baguettes
                    </Button>
                    <Button
                        href="#protein-packs"
                        class="btn-lewrap px-4 py-1 text-base leading-loose"
                    >
                        Protein Packs
                    </Button>
                    <Button
                        href="#salads"
                        class="btn-lewrap px-4 py-1 text-base leading-loose"
                    >
                        Salads
                    </Button>
                    {/*
                    NOTE: hidden kids meals for now. reinstate once menu item is available
                    <Button
                        href="#kids-meals"
                        class="btn-lewrap px-4 py-1 text-base leading-loose"
                    >
                        Kids Meals
                    </Button> */}
                    <Button
                        href="#sides"
                        class="btn-lewrap px-4 py-1 text-base leading-loose"
                    >
                        Sides
                    </Button>
                    <Button
                        href="#drinks"
                        class="btn-lewrap px-4 py-1 text-base leading-loose"
                    >
                        Drinks
                    </Button>
                </div>
            )
        }

        {
            subtitle && (
                <p
                    class="text-xl md:text-2xl leading-tight text-white text-center max-w-2xl px-8 mx-auto"
                    data-editable="text"
                    data-prop="hero_subtitle"
                    data-cms-bind="#hero_subtitle"
                >
                    {subtitle}
                </p>
            )
        }

        {/* Search Box (only shows on Locations page) */}
        {
            show_search && (
                <div class="w-full max-w-2xl flex flex-col">
                    <div class="flex flex-col md:flex-row gap-2">
                        <div class="relative flex-1">
                            <svg
                                class="absolute left-4 top-1/2 -translate-y-1/2 z-10 pointer-events-none"
                                width="28"
                                height="36"
                                viewBox="0 0 28 36"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M13.809 5.29092C9.11849 5.29092 5.29102 9.1184 5.29102 13.8089C5.29102 18.4995 9.11849 22.2894 13.809 22.2894C18.4996 22.2894 22.327 18.4619 22.327 13.7714C22.327 9.08087 18.4996 5.29092 13.809 5.29092ZM13.809 20.038C10.3568 20.038 7.54247 17.2236 7.54247 13.7714C7.54247 10.3192 10.3568 7.50486 13.809 7.50486C17.2613 7.50486 20.0756 10.3192 20.0756 13.7714C20.0756 17.2612 17.2613 20.038 13.809 20.038Z"
                                    fill="#95BA32"
                                />
                                <path
                                    d="M13.8089 0C6.1915 0 0 6.1915 0 13.7714C0 16.5107 0.825534 19.1749 2.3265 21.4263L11.1072 34.5598C12.0828 36.0608 14.1091 36.4361 15.5726 35.4604C15.9478 35.2353 16.248 34.8976 16.4731 34.5598L25.2538 21.4263C29.4941 15.0848 27.768 6.52922 21.4264 2.28898C19.1749 0.788009 16.5482 0 13.8089 0ZM23.4151 20.188L14.6345 33.3215C14.3343 33.7718 13.7339 33.8844 13.2836 33.5842C13.171 33.5092 13.096 33.4341 13.0209 33.3215L4.24024 20.188C0.712961 14.8971 2.13888 7.73 7.4298 4.20272C12.7207 0.675437 19.8879 2.10136 23.4151 7.39228C26.0043 11.2573 26.0043 16.3231 23.4151 20.188Z"
                                    fill="#95BA32"
                                />
                            </svg>

                            <input
                                type="text"
                                id="postcode-search"
                                placeholder="Type in your postcode..."
                                class="w-full pl-13 pr-6 py-6 rounded-lg outline-none focus:border-lewrap-green bg-white text-lewrap-off-black font-medium"
                                maxlength="4"
                            />
                        </div>
                        <div class="flex flex-row gap-2">
                            <Button
                                id="search-btn"
                                variant="secondary"
                                class="w-full md:w-auto"
                            >
                                Search
                            </Button>
                            <Button
                                id="clear-btn"
                                class="hidden bg-white/80 text-lewrap-green-dark font-normal w-full md:w-auto"
                            >
                                Clear
                            </Button>
                        </div>
                    </div>
                    <p
                        class="text-sm md:text-lg md:text-lg text-white/90 mt-4 text-center"
                        id="search-message"
                    >
                        We'll show you the closest LeWrap locations
                    </p>
                    <Button
                        href="#locations"
                        class="text-base mx-auto mt-5 w-full md:w-auto"
                    >
                        View all locations
                    </Button>
                </div>
            )
        }

        {/* Button */}
        {
            hero_button_text && hero_button_link && (
                <div class="mt-2">
                    <Button
                        href={hero_button_link}
                        variant={hero_button_variant}
                        target={targetAttr}
                        download={downloadAttr}
                    >
                        {hero_button_text}
                    </Button>
                </div>
            )
        }
    </div>
</section>
