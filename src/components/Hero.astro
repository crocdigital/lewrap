---
import Button from "../components/atoms/Button.astro";

const {
    title,
    subtitle,
    hero_bg_type = "color",
    hero_bg_colour = "#your-lewrap-green-hex", // Replace with your actual hex value
    hero_bg_image,
    hero_button_text,
    hero_button_link,
    hero_button_variant = "primary",
} = Astro.props;

// Determine background style
let backgroundStyle = "";
let showColorBackground = false;

if (hero_bg_type === "color" && hero_bg_colour) {
    backgroundStyle = `background-color: ${hero_bg_colour};`;
    showColorBackground = true;
} else if (hero_bg_type === "image" && hero_bg_image) {
    // Image will be rendered as <img> tag instead
    showColorBackground = false;
}
---

<section
    class="relative flex items-center justify-center mt-10 md:mt-15 w-[95%] mx-auto h-[62vh] md:h-[75vh] rounded-2xl overflow-hidden"
    style={showColorBackground ? backgroundStyle : ""}
>
    {/* Background Image (if selected) */}
    {
        hero_bg_type === "image" && hero_bg_image && (
            <img
                src={hero_bg_image}
                alt={title || "Hero background"}
                class="absolute inset-0 w-full h-full object-cover z-0"
            />
        )
    }

    {/* Gradient Overlay */}
    <div
        class="absolute inset-0 w-full h-full bg-gradient-to-b from-black/0 to-black/40 z-10"
    >
    </div>

    {/* Content */}
    <div
        class="max-w-[930px] relative z-20 flex flex-col items-center justify-center h-full w-full gap-y-6"
    >
        {
            title && (
                <h1
                    class="md:w-auto mx-auto text-white text-4xl md:text-[90px] font-bold leading-[100%] tracking-tight text-center"
                    data-editable="text"
                    data-prop="hero_title"
                    data-cms-bind="#hero_title"
                >
                    {title}
                </h1>
            )
        }

        {
            subtitle && (
                <p
                    class="text-xl md:text-2xl leading-tight text-white text-center max-w-2xl px-8 mx-auto"
                    data-editable="text"
                    data-prop="hero_subtitle"
                    data-cms-bind="#hero_subtitle"
                >
                    {subtitle}
                </p>
            )
        }

        {/* Button */}
        {
            hero_button_text && hero_button_link && (
                <div class="mt-2">
                    <Button
                        href={hero_button_link}
                        variant={hero_button_variant}
                    >
                        {hero_button_text}
                    </Button>
                </div>
            )
        }
    </div>
</section>
