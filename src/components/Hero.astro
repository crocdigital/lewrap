---
const {
    hero_title,
    hero_subtitle,
    bg_color = "bg-lewrap-green", // Default color if none selected
} = Astro.props;
---

<section
    class={`relative flex items-center justify-center mt-10 md:mt-15 w-[95%] mx-auto h-[62vh] md:h-[75vh] rounded-2xl overflow-hidden ${bg_color}`}
>
    <div class="max-w-4xl mx-auto px-6 flex flex-col gap-y-2 md:gap-y-6">
        {
            hero_title && (
                <h1 class="md:w-auto mx-auto text-white text-4xl md:text-[90px] font-bold leading-[100%] tracking-tight text-center">
                    {hero_title}
                </h1>
            )
        }

        {
            hero_subtitle && (
                <p class="text-xl md:text-2xl leading-tight text-white text-center max-w-2xl mx-auto">
                    {hero_subtitle}
                </p>
            )
        }
    </div>
</section>
