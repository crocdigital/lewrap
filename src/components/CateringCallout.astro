---
interface Props {
    image: string;
    title: string;
    description: string;
}

const { image, title, description } = Astro.props;
---

<div
    class="bg-white rounded-xl p-6 flex flex-col gap-4 items-center text-center"
>
    <img src={image} alt={title} class="w-24 h-24" />
    <h3 class="text-2xl font-bold text-lewrap-green-dark">
        {title}
    </h3>
    <p class="text-lewrap-off-black">
        {description}
    </p>
</div>
