---
interface Props {
    image: string;
    title: string;
    description: string;
}

const { image, title, description } = Astro.props;
---

<div class="flex flex-col gap-4 text-center">
    <img src={image} alt={title} class="w-70 h-70 rounded-xl mx-auto" />
    <h3 class="text-2xl/8 font-bold text-lewrap-green capitalize">
        {title}
    </h3>
    <p class="w-4/5 mx-auto text-lg text-lewrap-off-black">
        {description}
    </p>
</div>
