---
const { class: className = "" } = Astro.props;
---

<div
    class:list={[
        "left-scroll-reveal opacity-0 -translate-x-24 transition-all duration-700 ease-out transform",
        className,
    ]}
>
    <slot />
</div>

<script>
    function initLeftScrollReveal() {
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.remove(
                            "opacity-0",
                            "-translate-x-24",
                        );
                        entry.target.classList.add(
                            "opacity-100",
                            "translate-x-0",
                        );
                        observer.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
        );

        document.querySelectorAll(".left-scroll-reveal").forEach((el) => {
            observer.observe(el);
        });
    }

    // Run on load and after view transitions
    initLeftScrollReveal();
    document.addEventListener("astro:page-load", initLeftScrollReveal);
</script>
