---
import Button from "../components/atoms/Button.astro";

const {
    heading,
    text,
    image_path,
    video_url, // ← Add this
    reverse = false,
    blockIndex,
    background_type = "none",
    background_colour,
    background_image,
    button_text,
    button_link,
    button_variant = "primary",
    index = 0,
} = Astro.props;

// Determine inline style for backgrounds
let backgroundStyle = "";
if (background_type === "color" && background_colour) {
    backgroundStyle = `background-color: ${background_colour};`;
} else if (background_type === "image" && background_image) {
    backgroundStyle = `background-image: url('${background_image}'); background-repeat: repeat;`;
}

// Extract Vimeo video ID from URL
let vimeoId = "";
if (video_url) {
    const match = video_url.match(/vimeo\.com\/(\d+)/);
    if (match) vimeoId = match[1];
}
---

