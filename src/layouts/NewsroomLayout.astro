---
import BaseLayout from "./BaseLayout.astro";
import Button from "../components/atoms/Button.astro";

const { frontmatter } = Astro.props;
const { title, hero_image, hero_image_mobile, category, date, preview_text } =
    frontmatter;

// Format date
const formattedDate = new Intl.DateTimeFormat("en-AU", {
    day: "numeric",
    month: "long",
    year: "numeric",
}).format(new Date(date));
---

<BaseLayout title={title}>
    <article
        class="max-w-screen-2xl w-full mx-auto text-lewrap-off-black flex flex-col gap-10 relative"
    >
        <section
            class="relative flex items-center justify-center mt-10 md:mt-15 w-[95%] mx-auto h-[62vh] md:h-[75vh] rounded-2xl overflow-hidden bg-lewrap-green"
        >
            <div
                class="absolute inset-0 w-full h-full bg-gradient-to-b from-black/0 to-black/40 z-10"
            >
            </div>
            {/* Hero Image - Responsive */}
            <picture class="absolute inset-0 w-full h-full z-0">
                <source
                    media="(max-width: 768px)"
                    srcset={hero_image_mobile || hero_image}
                />
                <img
                    src={hero_image}
                    alt={title}
                    class="w-full h-full object-cover"
                />
            </picture>
        </section>

        {/* Meta Info */}
        <div class="flex items-center gap-4 mb-6">
            <span
                class="px-4 py-2 bg-lewrap-green text-white rounded-full text-sm font-semibold"
            >
                {category}
            </span>
            <time datetime={date.toISOString()} class="text-gray-600">
                {formattedDate}
            </time>
        </div>

        {/* Title */}
        <h1 class="text-4xl md:text-6xl font-bold text-lewrap-green-dark mb-6">
            {title}
        </h1>

        {/* Preview Text */}
        <p class="text-xl text-gray-700 mb-8 font-medium">
            {preview_text}
        </p>

        {/* Article Content */}
        <div
            class="prose prose-lg max-w-none
            prose-headings:text-lewrap-green-dark
            prose-h2:text-3xl prose-h2:font-bold prose-h2:mt-12 prose-h2:mb-4
            prose-h3:text-2xl prose-h3:font-semibold prose-h3:mt-8 prose-h3:mb-3
            prose-p:text-lg prose-p:leading-relaxed prose-p:mb-6
            prose-a:text-lewrap-green prose-a:font-semibold hover:prose-a:underline
            prose-strong:text-lewrap-green-dark
            prose-img:rounded-xl prose-img:shadow-lg
            prose-ul:list-disc prose-ul:pl-6
            prose-ol:list-decimal prose-ol:pl-6"
        >
            <slot />
        </div>

        {/* Back Button */}
        <div class="mt-16 pt-8 border-t border-gray-200">
            <Button href="/newsroom" variant="secondary">
                ← Back to Newsroom
            </Button>
        </div>
    </article>
</BaseLayout>
