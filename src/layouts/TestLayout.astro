---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Feature from "../components/Feature.astro";

const { frontmatter } = Astro.props;
const {
    title,
    hero_title,
    hero_subtitle,
    hero_bg,
    page_blocks = [],
} = frontmatter || {};
---

<BaseLayout title={title}>
    <main
        class="max-w-screen-2xl w-full mx-auto text-lewrap-off-black flex flex-col gap-5"
    >
        {/* FIXED HERO */}
        {
            hero_title && (
                <Hero
                    title={hero_title}
                    subtitle={hero_subtitle}
                    bg_color={hero_bg}
                />
            )
        }

        {/* DYNAMIC BLOCKS */}
        <div class="flex flex-col gap-5">
            {
                page_blocks?.map((block: any, index: number) => {
                    if (block._template === "feature") {
                        // 1. SET THE SCOPE
                        // We bind the WRAPPER to the specific block index.
                        // This creates a "Context" for the component inside.
                        return (
                            <div
                                data-cms-bind={`#page_blocks[${index}]`}
                                class="relative"
                            >
                                <Feature {...block} />
                            </div>
                        );
                    }
                    return null;
                })
            }
        </div>
    </main>
</BaseLayout>
