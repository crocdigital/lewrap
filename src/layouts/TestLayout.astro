---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Feature from "../components/Feature.astro";

const { frontmatter } = Astro.props;
const {
    title,
    hero_title,
    hero_subtitle,
    hero_bg,
    page_blocks = [],
} = frontmatter || {};
---

<BaseLayout title={title}>
    <main
        class="max-w-screen-2xl w-full mx-auto text-lewrap-off-black flex flex-col gap-5"
    >
        {/* FIXED HERO (Works perfectly as is) */}
        {
            hero_title && (
                <Hero
                    title={hero_title}
                    subtitle={hero_subtitle}
                    bg_color={hero_bg}
                />
            )
        }

        {/* DYNAMIC BLOCKS */}
        <div class="flex flex-col gap-5">
            {
                page_blocks?.map((block: any, index: number) => {
                    // 1. Define the Parent Scope: #page_blocks[0], #page_blocks[1]...
                    const blockBind = `#page_blocks[${index}]`;

                    if (block._template === "feature") {
                        return (
                            // 2. Wrap the component.
                            // This tells CloudCannon: "Everything inside here belongs to this block index."
                            <div data-cms-bind={blockBind}>
                                <Feature {...block} />
                            </div>
                        );
                    }
                    return null;
                })
            }
        </div>
    </main>
</BaseLayout>
