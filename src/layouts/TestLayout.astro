---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Feature from "../components/Feature.astro";
import CenteredText from "../components/CenteredText.astro";

const { frontmatter } = Astro.props;
const {
    title,
    hero_title,
    hero_subtitle,
    hero_bg,
    page_blocks = [],
} = frontmatter || {};
---

<BaseLayout title={title}>
    <main
        class="max-w-screen-2xl w-full mx-auto text-lewrap-off-black flex flex-col gap-10"
    >
        {
            hero_title && (
                <Hero
                    title={hero_title}
                    subtitle={hero_subtitle}
                    bg_color={hero_bg}
                />
            )
        }

        <div class="flex flex-col gap-10">
            {
                page_blocks?.map((block: any, index: number) => {
                    if (block._template === "feature") {
                        return <Feature {...block} blockIndex={index} />;
                    }
                    if (block._template === "centered_text") {
                        return <CenteredText {...block} blockIndex={index} />;
                    }
                    return null;
                })
            }
        </div>
    </main>
</BaseLayout>
