---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import TwoCol from "../components/TwoCol.astro";
import OneCol from "../components/OneCol.astro";

const { frontmatter } = Astro.props;
const {
    title,
    hero_title,
    hero_subtitle,
    hero_bg_type,
    hero_bg_color,
    hero_bg_image,
    page_blocks = [],
} = frontmatter || {};
---

<!-- NOTE FOR DEV: LOOK AT GEMINI ON PHONE FOR HOW TO TREAT THIS LAYOUT FOR INTERNAL PAGES USING SLOTS (ACTUALLY NOT SURE NOW BASED ON PAGES BEING MD FILES? IT SAYS THEY NEED TO BE MDX. DO A TEST ONE TRIALLING THIS) -->
<BaseLayout title={title}>
    <main
        class="max-w-screen-2xl w-full mx-auto text-lewrap-off-black flex flex-col gap-10"
    >
        {
            hero_title && (
                <Hero
                    title={hero_title}
                    subtitle={hero_subtitle}
                    hero_bg_type={hero_bg_type}
                    hero_bg_color={hero_bg_color}
                    hero_bg_image={hero_bg_image}
                />
            )
        }

        <div class="flex flex-col gap-10">
            {
                page_blocks?.map((block: any, index: number) => {
                    if (block._template === "feature") {
                        return <TwoCol {...block} blockIndex={index} />;
                    }
                    if (block._template === "centered_text") {
                        return <OneCol {...block} blockIndex={index} />;
                    }
                    return null;
                })
            }
        </div>
    </main>
</BaseLayout>
