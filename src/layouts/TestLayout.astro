---
// 1. Imports
import Hero from "../components/Hero.astro";
import Feature from "../components/Feature.astro";

// 2. Destructure props
// We set default values (= []) to stop crashes if data is missing
const {
    title,
    hero_title,
    hero_subtitle,
    hero_bg,
    page_blocks = [],
} = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{title}</title>
    </head>
    <body>
        {
            hero_title && (
                <Hero
                    title={hero_title}
                    subtitle={hero_subtitle}
                    bg_color={hero_bg}
                />
            )
        }

        <main>
            {
                page_blocks?.map((block: any) => {
                    // match the '_template' from your YAML
                    if (block._template === "feature") {
                        return <Feature {...block} />;
                    }
                    return null;
                })
            }
        </main>
    </body>
</html>
