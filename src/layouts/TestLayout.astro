---
// 1. Imports
import Hero from "../components/Hero.astro";
import Feature from "../components/Feature.astro";

// 2. Destructure props
// We set defaults (= []) to prevent crashes if data is missing
const {
    title,
    hero_title,
    hero_subtitle,
    hero_bg,
    page_blocks = [],
} = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{title}</title>
    </head>
    <body>
        <h1
            style="background: red; color: white; padding: 20px; font-size: 40px; text-align: center; z-index: 9999; position: relative;"
        >
            CAN YOU SEE ME?
        </h1>

        <div
            style="background: #f4f4f4; padding: 20px; border: 2px solid black; margin: 20px;"
        >
            <h3>DEBUG DATA:</h3>
            <pre>{JSON.stringify(Astro.props, null, 2)}</pre>
        </div>

        {
            hero_title && (
                <Hero
                    title={hero_title}
                    subtitle={hero_subtitle}
                    bg_color={hero_bg}
                />
            )
        }

        <main>
            {/* The ': any' fixes the TypeScript error */}
            {
                page_blocks?.map((block: any) => {
                    // Match the '_template' from your YAML
                    if (block._template === "feature") {
                        return <Feature {...block} />;
                    }
                    return null;
                })
            }
        </main>
    </body>
</html>
