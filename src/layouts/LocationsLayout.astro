---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

// Page Builder components
import Hero from "../components/Hero.astro";
import LocationCard from "../components/LocationCard.astro";

// Marquee component
import Marquee from "../components/molecules/Marquee.astro";
import { marqueeSeparator } from "../data/marqueeSeparator";

// Get all locations
const allLocations = (await getCollection(
    "locations",
)) as CollectionEntry<"locations">[];
const sortedLocations = allLocations.sort((a, b) =>
    a.data.suburb.localeCompare(b.data.suburb),
);

// Serialize locations data for client-side JS
const locationsData = sortedLocations.map((loc) => ({
    name: loc.data.name,
    address: loc.data.address,
    suburb: loc.data.suburb,
    state: loc.data.state,
    postcode: loc.data.postcode,
    slug: loc.slug,
    latitude: loc.data.latitude,
    longitude: loc.data.longitude,
}));

const { frontmatter } = Astro.props;
const {
    title,
    hero_title,
    hero_subtitle,
    hero_bg_type,
    hero_bg_colour,
    hero_bg_image,
    hero_bg_image_mobile,
    hero_button_text,
    hero_button_link,
    hero_button_variant,
    show_arrow_green_regular = false,
    show_arrow_blue = false,
    marquee_items = [],
} = frontmatter || {};
---

<BaseLayout title={title}>
    <main
        class="max-w-screen-2xl w-full mx-auto text-lewrap-off-black flex flex-col gap-10 relative"
    >
        {
            hero_title && (
                <Hero
                    title={hero_title}
                    subtitle={hero_subtitle}
                    hero_bg_type={hero_bg_type}
                    hero_bg_colour={hero_bg_colour}
                    hero_bg_image={hero_bg_image}
                    hero_bg_image_mobile={hero_bg_image_mobile}
                    hero_button_text={hero_button_text}
                    hero_button_link={hero_button_link}
                    hero_button_variant={hero_button_variant}
                    show_search={true}
                />
            )
        }

        {/* Conditionally render the arrow */}
        {
            show_arrow_green_regular && (
                <img
                    src="/images/elements/arrow-green-regular.svg"
                    alt="More about LeWrap"
                    class="w-10 h-auto absolute left-1/2 -translate-x-1/2 top-[calc(65vh-2.5rem)] md:top-[calc(79vh-2.5rem)] z-20"
                />
            )
        }

        {/* Only shows if marquee_items exist */}
        {
            marquee_items.length > 0 && (
                <Marquee
                    items={marquee_items}
                    separator={marqueeSeparator}
                    className="w-[95%] mx-auto bg-lewrap-green py-4 rounded-2xl"
                    gradientColor="#95BA32"
                    speed={50}
                />
            )
        }

        {/* Locations Grid */}
        <div
            id="locations"
            class="w-[95%] md:max-w-screen-lg mx-auto scroll-mt-32"
        >
            <h2
                class="text-3xl font-bold text-lewrap-green-dark mb-6"
                id="locations-heading"
            >
                Our locations ({sortedLocations.length})
            </h2>

            <div class="flex flex-col gap-6" id="locations-grid">
                {
                    sortedLocations.map((store) => (
                        <LocationCard
                            name={store.data.name}
                            address={store.data.address}
                            suburb={store.data.suburb}
                            state={store.data.state}
                            postcode={store.data.postcode}
                            slug={store.slug}
                        />
                    ))
                }
            </div>
        </div>
    </main>
</BaseLayout>

<script define:vars={{ locationsData }}>
    // Australian postcode to lat/long lookup (simplified version)
    const postcodeCoords = {
        "2150": { lat: -33.8152, lng: 151.0016 }, // Parramatta
        "2022": { lat: -33.8915, lng: 151.2506 }, // Bondi Junction
        "2000": { lat: -33.8688, lng: 151.2093 }, // Sydney CBD
        "2067": { lat: -33.7969, lng: 151.1835 }, // Chatswood
        "2040": { lat: -33.8812, lng: 151.1718 }, // Leichhardt/Lilyfield
    };

    // Calculate distance between two coordinates (Haversine formula)
    function calculateDistance(lat1, lon1, lat2, lon2) {
        const R = 6371; // Earth's radius in km
        const dLat = ((lat2 - lat1) * Math.PI) / 180;
        const dLon = ((lon2 - lon1) * Math.PI) / 180;
        const a =
            Math.sin(dLat / 2) * Math.sin(dLat / 2) +
            Math.cos((lat1 * Math.PI) / 180) *
                Math.cos((lat2 * Math.PI) / 180) *
                Math.sin(dLon / 2) *
                Math.sin(dLon / 2);
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        return R * c;
    }

    // Create location card HTML matching LocationCard.astro
    function createLocationCardHTML(loc) {
        return `
            <div class="border border-[#CBCBCB] bg-white rounded-xl overflow-hidden">
                <div class="p-6 flex grid md:grid-cols-2 justify-between gap-4">
                    <div>
                        <a href="/locations/${loc.slug}" class="text-2xl font-bold text-lewrap-green">
                            ${loc.name}
                        </a>
                        <div class="text-lewrap-off-black mt-2">
                            <p>${loc.address}</p>
                            <p>${loc.suburb}, ${loc.state} ${loc.postcode}</p>
                        </div>
                        ${
                            loc.distance !== undefined
                                ? `
                            <div class="text-slate-400 mt-2">
                                📍 ${loc.distance.toFixed(1)} km away
                            </div>
                        `
                                : ""
                        }
                    </div>
                    <div class="flex md:flex-col md:items-end mt-2 md:mt-0 gap-3">
                        <a href="/locations/${loc.slug}" class="btn-lewrap px-5 py-3 text-base leading-loose">
                            More Info
                        </a>
                        <a href="#" class="btn-lewrap-secondary px-5 py-3 text-base">
                            Order now
                        </a>
                    </div>
                </div>
            </div>
        `;
    }

    // Render location cards
    function renderLocations(locations) {
        const grid = document.getElementById("locations-grid");
        if (!grid) return;

        grid.innerHTML = locations
            .map((loc) => createLocationCardHTML(loc))
            .join("");
    }

    // Search functionality
    function searchLocations() {
        const input = document.getElementById("postcode-search");
        const searchBtn = document.getElementById("search-btn");
        const clearBtn = document.getElementById("clear-btn");
        const message = document.getElementById("search-message");
        const heading = document.getElementById("locations-heading");

        if (!input || !searchBtn || !clearBtn || !message || !heading) return;

        searchBtn.addEventListener("click", () => {
            const postcode = input.value.trim();

            if (!postcode || postcode.length !== 4) {
                message.textContent =
                    "⚠️ Please enter a valid 4-digit postcode";
                message.className = "text-sm text-center text-red-600 mt-4";
                return;
            }

            const userCoords = postcodeCoords[postcode];

            if (!userCoords) {
                message.textContent = `⚠️ Postcode ${postcode} not found. Showing all locations.`;
                message.className = "text-sm text-center text-orange-600 mt-4";
                renderLocations(locationsData);
                return;
            }

            // Calculate distances and sort
            const locationsWithDistance = locationsData
                .map((loc) => ({
                    ...loc,
                    distance: calculateDistance(
                        userCoords.lat,
                        userCoords.lng,
                        loc.latitude,
                        loc.longitude,
                    ),
                }))
                .sort((a, b) => a.distance - b.distance);

            renderLocations(locationsWithDistance);

            message.textContent = `✅ Showing locations nearest to ${postcode}`;
            message.className =
                "text-sm text-center text-lewrap-green font-semibold mt-4";

            heading.textContent = `Locations near ${postcode} (${locationsData.length})`;

            clearBtn.classList.remove("hidden");
        });

        // Clear search
        clearBtn.addEventListener("click", () => {
            input.value = "";
            renderLocations(locationsData);
            message.textContent = "We'll show you the closest LeWrap locations";
            message.className = "text-sm text-white/90 mt-4 text-center";
            heading.textContent = `Our locations (${locationsData.length})`;
            clearBtn.classList.add("hidden");
        });

        // Allow Enter key to search
        input.addEventListener("keypress", (e) => {
            if (e.key === "Enter") {
                searchBtn.click();
            }
        });
    }

    // Initialize on page load
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", searchLocations);
    } else {
        searchLocations();
    }

    // Also run after view transitions
    document.addEventListener("astro:page-load", searchLocations);
</script>
