---
import BaseLayout from "./BaseLayout.astro";
import Carousel from "../components/molecules/Carousel";

// Flexible 2 column component
import FlexibleTwoCol from "../components/FlexibleTwoCol.astro";

// Marquee component
import Marquee from "../components/molecules/Marquee.astro";
import { marqueeSeparator } from "../data/marqueeSeparator";

import { Image } from "astro:assets";
import leWrapLogo from "../assets/brand/lewrap-white.svg";

import Button from "../components/atoms/Button.astro";
import ScrollReveal from "../components/molecules/ScrollReveal.astro";
import bgTexture from "../assets/bgrds/bg-texture.webp";

const { frontmatter } = Astro.props;
const {
    title = "LeWrap - Fresh, Healthy Wraps",
    hero_slides = [],
    hero_heading = "We believe in all things good and fresh",
    hero_cta1_text = "Our food",
    hero_cta1_link = "/our-food",
    hero_cta2_text = "Order now",
    hero_cta2_link = "/order",
    marquee_items = [],
    welcome_heading = "Nõbody makës ă wrap like us",
    welcome_text = "",
    welcome_image = "",
    welcome_button_text = "Our Food",
    welcome_button_link = "/our-food",
    flexible_two_col = [],
} = frontmatter || {};

// Transform hero slides with HTML content for responsive images
const carouselSlides = hero_slides.map((slide: any) => {
    const mobileSrc = slide.image_mobile || slide.image_desktop;
    const desktopSrc = slide.image_desktop;
    const alt = slide.alt || "LeWrap hero image";

    return {
        type: "html" as const,
        content: `
            <picture>
                <source media="(max-width: 768px)" srcset="${mobileSrc}" />
                <img
                    src="${desktopSrc}"
                    alt="${alt}"
                    class="w-full h-full object-cover"
                />
            </picture>
        `,
    };
});
---

<BaseLayout title={title}>
    <main class="max-w-screen-2xl w-full mx-auto text-lewrap-off-black">
        <div class="flex flex-col gap-5">
            {/* Hero Carousel */}
            <section class="mt-10 md:mt-15">
                <Carousel
                    client:load
                    slides={carouselSlides}
                    showPagination={true}
                    showNavigation={true}
                    autoplay={{
                        delay: 5000,
                        disableOnInteraction: false,
                    }}
                    cta={{
                        text: hero_cta1_text,
                        href: hero_cta1_link,
                    }}
                    cta2={{
                        text: hero_cta2_text,
                        href: hero_cta2_link,
                    }}
                    loop={true}
                    hasGradient={true}
                    className="w-[95%] mx-auto h-[62vh] md:h-[75vh] rounded-2xl overflow-hidden"
                >
                    {/* Content overlay */}
                    <div
                        class="max-w-6xl flex flex-col items-center text-center z-30 pointer-events-none select-none"
                    >
                        <Image
                            src={leWrapLogo}
                            alt="LeWrap"
                            class="w-[128px] h-[37px] md:w-[266px] md:h-[78px]"
                        />
                        <h1
                            class="text-white text-4xl md:text-[90px] w-3/4 md:w-auto font-bold leading-[100%] tracking-tight"
                            data-cms-bind="#hero_heading"
                        >
                            {hero_heading}
                        </h1>
                    </div>
                </Carousel>
            </section>

            {/* Marquee */}
            {
                marquee_items.length > 0 && (
                    <Marquee
                        items={marquee_items}
                        separator={marqueeSeparator}
                        className="w-[95%] mx-auto bg-lewrap-green py-4 rounded-2xl"
                        gradientColor="#95BA32"
                        speed={50}
                    />
                )
            }

            {/* Welcome Section */}
            <section
                class="w-[95%] mx-auto bg-cover bg-center bg-no-repeat p-7 rounded-2xl grid md:grid-cols-2 relative"
                style={{
                    backgroundImage: `radial-gradient(ellipse 93.38% 101.86% at 50% 50%, white 15%, rgba(255, 255, 255, 0) 100%), url(${bgTexture.src})`,
                }}
            >
                <div class="max-w-xl mx-auto flex flex-col gap-y-8 py-16">
                    <h2
                        class="text-lewrap-green-dark text-5xl/11 md:text-6xl/14 font-black tracking-tight"
                        data-editable="text"
                        data-prop="welcome_heading"
                        data-cms-bind="#welcome_heading"
                    >
                        {welcome_heading}
                    </h2>

                    <div
                        class="text-2xl/8 prose [&_p]:mb-6"
                        data-editable="text"
                        data-prop="welcome_text"
                        data-cms-bind="#welcome_text"
                        set:html={welcome_text}
                    />

                    {
                        welcome_button_text && welcome_button_link && (
                            <ScrollReveal>
                                <Button href={welcome_button_link}>
                                    {welcome_button_text}
                                </Button>
                            </ScrollReveal>
                        )
                    }
                </div>

                {
                    welcome_image && (
                        <img
                            src={welcome_image}
                            alt="LeWrap welcome"
                            class="w-[300px] md:w-[629px] h-auto block relative md:absolute mx-auto md:bottom-0 md:right-28 md:mx-0 mb-[-28px] md:mb-0"
                            loading="eager"
                        />
                    )
                }
            </section>

            {/* Find a LeWrap near you */}
            {
                flexible_two_col && flexible_two_col[0] && (
                    <section class="w-[95%] md:max-w-screen-2xl mx-auto gap-8 p-7 md:p-21 rounded-xl bg-white relative">
                        <FlexibleTwoCol
                            title={flexible_two_col[0].title}
                            description={flexible_two_col[0].description}
                            buttonText={flexible_two_col[0].buttonText}
                            buttonLink={flexible_two_col[0].buttonLink}
                            buttonVariant={flexible_two_col[0].buttonVariant}
                            bgColor={flexible_two_col[0].bgColor}
                            reverse={flexible_two_col[0].reverse}
                            slides={flexible_two_col[0].slides}
                            index={0}
                        />

                        <img
                            src="/images/elements/koftas.webp"
                            alt="More about LeWrap"
                            class="w-28 md:w-36 h-auto absolute -bottom-8 right-4"
                        />
                    </section>
                )
            }
        </div>
    </main>
</BaseLayout>
